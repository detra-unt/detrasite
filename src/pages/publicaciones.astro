---
import Layout from "../layouts/Layout.astro";
import PublicationsHero from "../components/PublicationsHero.astro";
import ArticlesFilters from "../components/ArticlesFilters.astro";
import ArticlePreviewCard from "../components/ArticlePreviewCard.astro";
import ContributeCTA from "../components/ContributeCTA.astro";
import {
  getArticles,
  getFeaturedArticles,
  getArticleTypeSlug,
} from "../lib/contentful";

const ARTICLES_PER_PAGE = 6;

// SSG: Cargar TODOS los artículos en build time (sin fetch en runtime)
const [featuredArticles, { articles, total }] = await Promise.all([
  getFeaturedArticles(),
  getArticles({ limit: 1000 }), // Cargar todos - el límite de Contentful es 1000
]);

const totalPages = Math.ceil(total / ARTICLES_PER_PAGE);
const hasMoreArticles = total > ARTICLES_PER_PAGE;

// Asignar cada artículo a su "página" visual
const articlesWithPage = articles.map((article, index) => ({
  ...article,
  page: Math.floor(index / ARTICLES_PER_PAGE) + 1,
}));
---

<Layout
  title="Publicaciones | DETRA-UNT"
  description="Repositorio de artículos de investigación jurídica de DETRA-UNT. Consulta estudios sobre derecho laboral publicados por estudiantes de la Universidad Nacional de Trujillo e investigadores invitados."
  currentPage="publications"
  keywords="publicaciones jurídicas, artículos de derecho, investigación legal, DETRA-UNT, repositorio académico, revistas de derecho Perú"
>
  <PublicationsHero total={total} />

  <main class="max-w-7xl mx-auto px-6 md:px-8 pb-8 md:pb-12">
    <!-- Artículos Destacados -->
    {
      featuredArticles.length > 0 && (
        <section class="mb-16 md:mb-20">
          <div class="flex items-center justify-between mb-8">
            <h2 class="font-headline text-2xl md:text-3xl text-primary font-bold">
              Artículos Destacados
            </h2>
            <span class="font-label text-sm text-on-surface-variant">
              Los más recientes de cada categoría
            </span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            {featuredArticles.map((article) => (
              <ArticlePreviewCard article={article} variant="featured" />
            ))}
          </div>
        </section>
      )
    }

    <!-- Filtros de búsqueda -->
    <ArticlesFilters />

    <!-- Todos los Artículos -->
    <section>
      <div
        class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8"
      >
        <h2 class="font-headline text-2xl md:text-3xl text-primary font-bold">
          Todos los Artículos
        </h2>
        <p
          id="articles-count"
          class="font-label text-sm text-on-surface-variant"
        >
          {total} artículo{total !== 1 ? "s" : ""} encontrado{
            total !== 1 ? "s" : ""
          }
        </p>
      </div>

      {
        articlesWithPage.length > 0 ? (
          <div
            id="articles-list"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
          >
            {articlesWithPage.map((article) => (
              <div
                data-article
                data-page={article.page}
                data-title={article.title}
                data-authors={article.authorsCollection.items
                  .map((a) => a.fullName)
                  .join(", ")}
                data-type={getArticleTypeSlug(article.articleType)}
                data-date={article.publishDate}
                class:list={[
                  "article-item",
                  { "hidden-page": article.page > 1 }
                ]}
              >
                <ArticlePreviewCard article={article} variant="default" />
              </div>
            ))}
          </div>
        ) : (
          <div class="text-center py-16 bg-surface-container rounded-xl">
            <span class="material-symbols-outlined text-6xl text-on-surface-variant/40 mb-4">
              article
            </span>
            <h3 class="font-headline text-xl text-on-surface-variant mb-2">
              No hay artículos disponibles
            </h3>
            <p class="font-body text-on-surface-variant/70">
              Los artículos aparecerán aquí una vez publicados en el sistema.
            </p>
          </div>
        )
      }

      <!-- Mensaje sin resultados (oculto por defecto) -->
      <div
        id="no-results"
        class="hidden text-center py-16 bg-surface-container rounded-xl"
      >
        <span
          class="material-symbols-outlined text-6xl text-on-surface-variant/40 mb-4"
          >search_off</span
        >
        <h3 class="font-headline text-xl text-on-surface-variant mb-2">
          No se encontraron artículos
        </h3>
        <p class="font-body text-on-surface-variant/70">
          Intenta con otros términos de búsqueda o ajusta los filtros.
        </p>
      </div>

      <!-- Paginación visual (SSG - sin fetch) -->
      {
        hasMoreArticles && (
          <div id="pagination-container" class="mt-12 md:mt-16">
            <!-- Indicador de progreso -->
            <div class="flex items-center justify-center gap-4 mb-6">
              <div class="h-px flex-1 max-w-24 bg-gradient-to-r from-transparent to-[#5E0B15]/20" />
              <p id="pagination-progress" class="font-label text-sm text-[#1c1c14]/60">
                Mostrando <span id="loaded-count" class="font-bold text-[#5E0B15]">{Math.min(ARTICLES_PER_PAGE, total)}</span> de <span id="total-count" class="font-bold">{total}</span> artículos
              </p>
              <div class="h-px flex-1 max-w-24 bg-gradient-to-l from-transparent to-[#5E0B15]/20" />
            </div>

            <!-- Barra de progreso visual -->
            <div class="max-w-md mx-auto mb-8">
              <div class="h-1.5 bg-[#5E0B15]/10 rounded-full overflow-hidden">
                <div 
                  id="progress-bar"
                  class="h-full bg-gradient-to-r from-[#5E0B15] to-[#5E0B15]/70 rounded-full transition-all duration-500 ease-out"
                  style={`width: ${(Math.min(ARTICLES_PER_PAGE, total) / total) * 100}%`}
                />
              </div>
            </div>

            <!-- Botón cargar más -->
            <div class="flex justify-center">
              <button
                id="load-more"
                class="group relative font-label text-sm font-bold text-[#5E0B15] py-4 px-10 border-2 border-[#5E0B15]/20 rounded-full hover:border-[#5E0B15] hover:bg-[#5E0B15] hover:text-white transition-all duration-300 shadow-sm hover:shadow-lg hover:shadow-[#5E0B15]/20 hover:-translate-y-0.5 overflow-hidden"
                data-current-page="1"
                data-total-pages={totalPages}
                data-per-page={ARTICLES_PER_PAGE}
                data-total={total}
              >
                {/* Efecto ripple en hover */}
                <span class="absolute inset-0 bg-[#5E0B15] scale-0 group-hover:scale-100 transition-transform duration-500 origin-center rounded-full" />
                
                {/* Contenido del botón */}
                <span class="relative flex items-center gap-3">
                  <span id="load-more-text">Cargar más artículos</span>
                  <span class="material-symbols-outlined text-lg transition-transform duration-300 group-hover:translate-y-0.5">
                    expand_more
                  </span>
                </span>
              </button>
            </div>

            <!-- Indicador de páginas -->
            <div class="flex justify-center mt-6 gap-2">
              {Array.from({ length: totalPages }).map((_, i) => (
                <span 
                  class:list={[
                    "pagination-dot w-2 h-2 rounded-full transition-all duration-300",
                    i === 0 ? "bg-[#5E0B15] scale-125" : "bg-[#5E0B15]/20"
                  ]}
                  data-page={i + 1}
                />
              ))}
            </div>
          </div>
        )
      }
    </section>
  </main>

  <ContributeCTA />
</Layout>

<style>
  /* Artículos ocultos por paginación (cargados pero no visibles) */
  .hidden-page {
    display: none;
  }
  
  /* Animación para artículos revelados */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.animate-fade-in-up) {
    animation: fadeInUp 0.5s ease-out forwards;
  }

  /* Stagger para múltiples elementos */
  :global(.animate-fade-in-up:nth-child(1)) { animation-delay: 0ms; }
  :global(.animate-fade-in-up:nth-child(2)) { animation-delay: 75ms; }
  :global(.animate-fade-in-up:nth-child(3)) { animation-delay: 150ms; }
  :global(.animate-fade-in-up:nth-child(4)) { animation-delay: 225ms; }
  :global(.animate-fade-in-up:nth-child(5)) { animation-delay: 300ms; }
  :global(.animate-fade-in-up:nth-child(6)) { animation-delay: 375ms; }
</style>

<script>
  // ============================================================================
  // PAGINACIÓN VISUAL SSG - Sin fetch, solo muestra/oculta contenido pre-cargado
  // ============================================================================
  
  document.addEventListener('astro:page-load', () => {
    const loadMoreBtn = document.getElementById("load-more") as HTMLButtonElement | null;
    if (!loadMoreBtn) return;

    const loadedCountEl = document.getElementById("loaded-count");
    const progressBar = document.getElementById("progress-bar");
    const paginationDots = document.querySelectorAll(".pagination-dot");

    // Obtener configuración desde data attributes
    let currentPage = parseInt(loadMoreBtn.dataset.currentPage || "1", 10);
    const totalPages = parseInt(loadMoreBtn.dataset.totalPages || "1", 10);
    const perPage = parseInt(loadMoreBtn.dataset.perPage || "6", 10);
    const totalArticles = parseInt(loadMoreBtn.dataset.total || "0", 10);

    /**
     * Actualiza la UI de paginación (contador, barra de progreso, dots)
     */
    const updatePaginationUI = () => {
      const visibleCount = currentPage * perPage;
      const actualVisible = Math.min(visibleCount, totalArticles);

      // Actualizar contador
      if (loadedCountEl) {
        loadedCountEl.textContent = String(actualVisible);
      }

      // Actualizar barra de progreso
      if (progressBar) {
        const percentage = (actualVisible / totalArticles) * 100;
        progressBar.style.width = `${percentage}%`;
      }

      // Actualizar dots de paginación
      paginationDots.forEach((dot, i) => {
        const dotEl = dot as HTMLElement;
        if (i + 1 <= currentPage) {
          dotEl.classList.remove("bg-[#5E0B15]/20");
          dotEl.classList.add("bg-[#5E0B15]");
          if (i + 1 === currentPage) {
            dotEl.classList.add("scale-125");
          } else {
            dotEl.classList.remove("scale-125");
          }
        } else {
          dotEl.classList.add("bg-[#5E0B15]/20");
          dotEl.classList.remove("bg-[#5E0B15]", "scale-125");
        }
      });

      // Ocultar botón si ya mostramos todos
      if (currentPage >= totalPages) {
        loadMoreBtn.style.display = "none";
        
        // Mostrar mensaje de fin
        const endMessage = document.createElement("p");
        endMessage.className = "text-center font-label text-sm text-[#1c1c14]/50 mt-4";
        endMessage.innerHTML = `
          <span class="inline-flex items-center gap-2">
            <span class="material-symbols-outlined text-base">check_circle</span>
            Has visto todos los artículos
          </span>
        `;
        loadMoreBtn.parentElement?.appendChild(endMessage);
      }
    };

    /**
     * Revela los artículos de la siguiente página con animación
     */
    const showNextPage = () => {
      currentPage++;
      loadMoreBtn.dataset.currentPage = String(currentPage);

      // Encontrar artículos de esta página y mostrarlos
      const articlesToShow = document.querySelectorAll(
        `[data-article][data-page="${currentPage}"]`
      );

      articlesToShow.forEach((article, index) => {
        const el = article as HTMLElement;
        // Quitar clase hidden-page
        el.classList.remove("hidden-page");
        // Agregar animación con stagger
        el.style.animationDelay = `${index * 75}ms`;
        el.classList.add("animate-fade-in-up");
      });

      updatePaginationUI();
    };

    // Event listener del botón
    loadMoreBtn.addEventListener("click", showNextPage);
  });
</script>
