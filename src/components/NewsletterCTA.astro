---
// src/components/ContactCTA.astro - Formulario de contacto
---

<section id="contacto" class="py-16 md:py-24 bg-[#5E0B15] text-white overflow-hidden relative">
  <div class="absolute top-0 right-0 w-1/3 h-full opacity-10 hidden md:block">
    <span class="material-symbols-outlined text-[300px] lg:text-[400px] -mr-32 -mt-16" style="font-variation-settings: 'FILL' 1;">
      mail
    </span>
  </div>

  <div class="max-w-5xl mx-auto px-6 md:px-8 relative z-10">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <div class="text-center md:text-left">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-headline font-bold mb-6">
          Contáctanos
        </h2>
        <p class="text-lg md:text-xl font-body text-[#ffb2b7] mb-8 leading-relaxed">
          ¿Tienes alguna consulta, propuesta o deseas colaborar con nosotros? Escríbenos y te responderemos a la brevedad.
        </p>
        <div class="space-y-4 text-[#ffdadb]">
          <div class="flex items-center gap-3 justify-center md:justify-start">
            <span class="material-symbols-outlined text-2xl">location_on</span>
            <span class="font-body">Trujillo, La Libertad - Perú</span>
          </div>
          <div class="flex items-center gap-3 justify-center md:justify-start">
            <span class="material-symbols-outlined text-2xl">school</span>
            <span class="font-body">Universidad Nacional de Trujillo</span>
          </div>
        </div>
      </div>

      <div class="bg-[#40000e] rounded-2xl p-6 md:p-8 shadow-xl shadow-black/20">
        <form class="space-y-4" action="#" method="POST">
          <div>
            <label for="nombre" class="block text-sm font-label text-[#ffb2b7] mb-2">Nombre completo</label>
            <input
              id="nombre"
              type="text"
              placeholder="Ingresa tu nombre"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder:text-white/40 focus:bg-white/20 focus:outline-none focus:ring-2 focus:ring-[#ffdadb] transition-all font-body"
              required
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-label text-[#ffb2b7] mb-2">Correo electrónico</label>
            <input
              id="email"
              type="email"
              placeholder="ejemplo@correo.com"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder:text-white/40 focus:bg-white/20 focus:outline-none focus:ring-2 focus:ring-[#ffdadb] transition-all font-body"
              required
            />
          </div>
          <div>
            <label for="asunto" class="block text-sm font-label text-[#ffb2b7] mb-2">Asunto</label>
            <select
              id="asunto"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white focus:bg-white/20 focus:outline-none focus:ring-2 focus:ring-[#ffdadb] transition-all font-body appearance-none cursor-pointer"
              required
            >
              <option value="" class="bg-[#40000e]">Selecciona un asunto</option>
              <option value="consulta" class="bg-[#40000e]">Consulta general</option>
              <option value="colaboracion" class="bg-[#40000e]">Propuesta de colaboración</option>
              <option value="revista" class="bg-[#40000e]">Información sobre la revista</option>
              <option value="admision" class="bg-[#40000e]">Proceso de admisión</option>
              <option value="otro" class="bg-[#40000e]">Otro</option>
            </select>
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-label text-[#ffb2b7] mb-2">Mensaje</label>
            <textarea
              id="mensaje"
              placeholder="Escribe tu mensaje aquí..."
              rows="4"
              class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder:text-white/40 focus:bg-white/20 focus:outline-none focus:ring-2 focus:ring-[#ffdadb] transition-all font-body resize-none"
              required
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full cursor-pointer bg-[#ffdadb] text-[#40000e] px-8 py-4 rounded-lg font-label font-bold text-lg hover:bg-white transition-all flex items-center justify-center gap-2"
          >
            <span>Enviar mensaje</span>
            <span class="material-symbols-outlined">send</span>
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
