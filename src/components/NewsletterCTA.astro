---
// src/components/NewsletterCTA.astro - Formulario de contacto con EmailJS
import ContactForm from './react/ContactForm';
---

<section id="contacto" class="contact-section">
  <!-- ── Decorative background elements ── -->
  <div class="contact-bg-number" aria-hidden="true">DEL</div>
  <div class="contact-bg-lines" aria-hidden="true">
    {
      Array.from({ length: 7 }).map((_, i) => (
        <span class="contact-bg-line" style={`animation-delay: ${i * 0.18}s`} />
      ))
    }
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-10 relative z-10">
    <div class="contact-grid">
      <!-- ── Left: Info ── -->
      <div class="contact-info">
        <p class="contact-eyebrow">
          <span class="contact-eyebrow__line"></span>
          Escríbenos
        </p>
        <h2 class="contact-headline">
          ¿Tienes algo<br />
          <em>que decirnos?</em>
        </h2>
        <p class="contact-description">
          Consultas, propuestas de colaboración o simplemente compartir tu
          entusiasmo por el Derecho. Estamos aquí.
        </p>
        <ul class="contact-details">
          <li class="contact-detail">
            <span
              class="contact-detail__icon material-symbols-outlined"
              style="font-variation-settings:'FILL' 1">location_on</span
            >
            <span>Trujillo, La Libertad — Perú</span>
          </li>
          <li class="contact-detail">
            <span
              class="contact-detail__icon material-symbols-outlined"
              style="font-variation-settings:'FILL' 1">school</span
            >
            <span>Universidad Nacional de Trujillo</span>
          </li>
        </ul>
      </div>

      <!-- ── Right: Form (React) ── -->
      <ContactForm client:load />
    </div>
  </div>
</section>

<style is:global>
  /* ═══════════════════════════════════════
     SECTION SHELL
  ═══════════════════════════════════════ */
  .contact-section {
    position: relative;
    overflow: hidden;
    background: #5e0b15;
    color: #fff;
    padding: 5rem 0 6rem;
  }
  @media (min-width: 768px) {
    .contact-section {
      padding: 7rem 0 8rem;
    }
  }

  .contact-bg-number {
    position: absolute;
    top: -0.5rem;
    right: -2rem;
    font-size: clamp(10rem, 22vw, 22rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    color: rgba(255, 255, 255, 0.025);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    font-family: Georgia, serif;
  }

  .contact-bg-lines {
    position: absolute;
    inset: 0;
    display: flex;
    gap: 4rem;
    pointer-events: none;
    opacity: 0.04;
  }
  .contact-bg-line {
    display: block;
    width: 1px;
    height: 100%;
    background: #fff;
  }

  /* ═══════════════════════════════════════
     GRID
  ═══════════════════════════════════════ */
  .contact-grid {
    display: grid;
    gap: 3.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 4rem;
    }
  }

  /* ═══════════════════════════════════════
     LEFT — INFO
  ═══════════════════════════════════════ */
  .contact-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #ffdadb;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .contact-eyebrow__line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: #ffdadb;
    opacity: 0.6;
  }
  .contact-headline {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: #fff;
  }
  .contact-headline em {
    font-style: italic;
    color: #ffdadb;
  }

  .contact-description {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 178, 183, 0.85);
    max-width: 32ch;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 767px) {
    .contact-description {
      max-width: 100%;
    }
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
  }
  .contact-detail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 218, 219, 0.8);
    font-size: 0.9rem;
  }
  .contact-detail__icon {
    font-size: 1.15rem;
    color: #ffdadb;
    opacity: 0.75;
  }

  /* ═══════════════════════════════════════
     RIGHT — CARD
  ═══════════════════════════════════════ */
  .contact-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 1.25rem;
    padding: 2.25rem;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04) inset,
      0 32px 64px rgba(0, 0, 0, 0.22);
  }
  @media (min-width: 768px) {
    .contact-card {
      padding: 2.75rem;
    }
  }

  /* ─── Success ─── */
  .contact-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.9rem;
    padding: 2rem 1rem;
  }
  .contact-success[hidden] {
    display: none;
  }
  .contact-success__icon {
    font-size: 3.5rem;
    color: #ffdadb;
  }
  .contact-success__title {
    font-family: Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
  }
  .contact-success__body {
    font-size: 0.9rem;
    color: #ffb2b7;
    line-height: 1.6;
  }
  .contact-success__reset {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 218, 219, 0.7);
    text-decoration: underline;
    text-underline-offset: 3px;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s;
  }
  .contact-success__reset:hover {
    color: #fff;
  }

  /* ─── Error banner ─── */
  .contact-error {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(180, 20, 30, 0.35);
    border: 1px solid rgba(255, 100, 100, 0.25);
    border-radius: 0.625rem;
    padding: 0.75rem 1rem;
    color: #ffb2b7;
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
  }
  .contact-error[hidden] {
    display: none;
  }

  /* ─── Form ─── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact-form.hidden {
    display: none;
  }

  .contact-form__row {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 520px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Shake animation for invalid submit */
  @keyframes cf-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    20% {
      transform: translateX(-6px);
    }
    40% {
      transform: translateX(6px);
    }
    60% {
      transform: translateX(-4px);
    }
    80% {
      transform: translateX(4px);
    }
  }
  .contact-form.shake {
    animation: cf-shake 0.4s ease;
  }

  /* ─── Fields ─── */
  .contact-field {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .contact-field__label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255, 178, 183, 0.75);
    transition: color 0.2s;
  }
  .contact-field:focus-within .contact-field__label,
  .contact-field.is-valid .contact-field__label {
    color: #ffdadb;
  }
  .contact-field.is-invalid .contact-field__label {
    color: #ffa0a8;
  }

  .contact-field__input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 0.95rem;
    padding: 0.55rem 0;
    width: 100%;
    outline: none;
    transition: border-color 0.25s;
    font-family: inherit;
  }
  .contact-field__input::placeholder {
    color: rgba(255, 255, 255, 0.28);
  }
  .contact-field__input:focus {
    border-color: rgba(255, 218, 219, 0.5);
  }

  .contact-field.is-invalid .contact-field__input {
    border-color: rgba(255, 100, 110, 0.55);
  }
  .contact-field.is-valid .contact-field__input {
    border-color: rgba(255, 218, 219, 0.35);
  }

  /* Animated focus bar */
  .contact-field__bar {
    position: absolute;
    bottom: 1.35rem;
    left: 0;
    width: 0;
    height: 1.5px;
    background: #ffdadb;
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }
  .contact-field:focus-within .contact-field__bar {
    width: 100%;
  }
  .contact-field.is-invalid .contact-field__bar {
    background: #ff7882;
    width: 100%;
  }

  /* Per-field error message */
  .contact-field__error {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: #ff9aa2;
    min-height: 0.9rem;
    transition: opacity 0.2s;
    opacity: 0;
  }
  .contact-field.is-invalid .contact-field__error {
    opacity: 1;
  }

  /* Textarea */
  .contact-field__textarea {
    resize: none;
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════
     CUSTOM SELECT DROPDOWN
  ═══════════════════════════════════════ */

  /* Trigger button */
  .cselect-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    text-align: left;
    gap: 0.5rem;
    padding-right: 0.25rem;
    /* override default button styles */
    -webkit-appearance: none;
    appearance: none;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
  }

  .cselect-trigger__text {
    flex: 1;
    color: rgba(255, 255, 255, 0.28); /* placeholder color */
    transition: color 0.2s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cselect-trigger.has-value .cselect-trigger__text {
    color: #fff;
  }

  .cselect-trigger__chevron {
    flex-shrink: 0;
    color: rgba(255, 218, 219, 0.5);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.2s;
  }

  .cselect-trigger.is-open .cselect-trigger__chevron {
    transform: rotate(180deg);
    color: #ffdadb;
  }

  /* Dropdown list panel */
  .cselect-list {
    position: absolute;
    top: calc(100% + 0.35rem);
    left: -1px;
    right: -1px;
    z-index: 50;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    background: #1e0007;
    border: 1px solid rgba(255, 218, 219, 0.18);
    border-radius: 0.625rem;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.55),
      0 4px 12px rgba(0, 0, 0, 0.3);
    /* Animated open/close */
    opacity: 0;
    transform: translateY(-6px) scaleY(0.94);
    transform-origin: top center;
    pointer-events: none;
    transition:
      opacity 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cselect-list.is-open {
    opacity: 1;
    transform: translateY(0) scaleY(1);
    pointer-events: auto;
  }

  /* Option items */
  .cselect-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    font-size: 0.9rem;
    color: rgba(255, 218, 219, 0.78);
    border-radius: 0.375rem;
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
    outline: none;
  }

  .cselect-option:hover,
  .cselect-option:focus {
    background: rgba(255, 218, 219, 0.1);
    color: #fff;
  }

  .cselect-option.is-selected {
    color: #ffdadb;
    background: rgba(255, 218, 219, 0.08);
  }

  .cselect-option__check {
    font-size: 0.9rem;
    color: #ffdadb;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .cselect-option.is-selected .cselect-option__check {
    opacity: 1;
  }

  /* Divider between options */
  .cselect-option + .cselect-option {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  /* Adjust bar position for the subject field (has the extra listbox) */
  #field-asunto .contact-field__bar {
    bottom: 1.75rem;
  }

  /* ─── Submit button ─── */
  .contact-submit {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.9rem 2rem;
    margin-top: 0.5rem;
    border: 1px solid rgba(255, 218, 219, 0.55);
    border-radius: 0.5rem;
    background: transparent;
    color: #ffdadb;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    overflow: hidden;
    transition:
      color 0.35s ease,
      border-color 0.35s ease;
  }

  .contact-submit::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #ffdadb;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 0;
  }
  .contact-submit:hover::before,
  .contact-submit:focus-visible::before {
    transform: scaleX(1);
  }
  .contact-submit:hover,
  .contact-submit:focus-visible {
    color: #40000e;
    border-color: #ffdadb;
  }
  .contact-submit > * {
    position: relative;
    z-index: 1;
  }
  .contact-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .contact-submit__icon {
    font-size: 1.1rem;
    transition: transform 0.3s ease;
  }
  .contact-submit:hover .contact-submit__icon {
    transform: translateX(3px) rotate(-10deg);
  }

  .contact-submit__spinner {
    width: 1.1rem;
    height: 1.1rem;
    animation: spin 0.8s linear infinite;
  }
  .contact-submit__spinner[hidden] {
    display: none;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
