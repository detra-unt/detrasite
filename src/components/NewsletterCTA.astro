---
// src/components/NewsletterCTA.astro - Formulario de contacto con EmailJS
import ContactForm from './react/ContactForm';

// Detectar si el usuario llega con un motivo específico (link directo al formulario)
// En ese caso, el formulario debe estar visible inmediatamente, usamos un rootMargin mayor
const hasMotivo = Astro.url.searchParams.has('motivo');
const rootMargin = hasMotivo ? "2000px" : "200px";
---

<section id="contacto" class="contact-section">
  <!-- ── Decorative background elements ── -->
  <div class="contact-bg-number" aria-hidden="true">DEL</div>
  <div class="contact-bg-lines" aria-hidden="true">
    {
      Array.from({ length: 7 }).map((_, i) => (
        <span class="contact-bg-line" style={`animation-delay: ${i * 0.18}s`} />
      ))
    }
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-10 relative z-10">
    <div class="contact-grid">
      <!-- ── Left: Info ── -->
      <div class="contact-info">
        <p class="contact-eyebrow">
          <span class="contact-eyebrow__line"></span>
          Escríbenos
        </p>
        <h2 class="contact-headline">
          ¿Tienes algo<br />
          <em>que decirnos?</em>
        </h2>
        <p class="contact-description">
          Consultas, propuestas de colaboración o simplemente compartir tu
          entusiasmo por el Derecho. Estamos aquí.
        </p>
        <ul class="contact-details">
          <li class="contact-detail">
            <span
              class="contact-detail__icon material-symbols-outlined"
              style="font-variation-settings:'FILL' 1">location_on</span
            >
            <span>Trujillo, La Libertad — Perú</span>
          </li>
          <li class="contact-detail">
            <span
              class="contact-detail__icon material-symbols-outlined"
              style="font-variation-settings:'FILL' 1">school</span
            >
            <span>Universidad Nacional de Trujillo</span>
          </li>
        </ul>
      </div>

      <!-- ── Right: Form (React) ── -->
      <!-- client:visible hidrata solo cuando el formulario entra en viewport -->
      <!-- rootMargin inicia la hidratación 200px antes (o 2000px si hay ?motivo=) -->
      <ContactForm client:visible={{ rootMargin }} />
    </div>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════
     SECTION SHELL (scoped to this component)
  ═══════════════════════════════════════ */
  .contact-section {
    position: relative;
    overflow: hidden;
    background: #5e0b15;
    color: #fff;
    padding: 5rem 0 6rem;
  }
  @media (min-width: 768px) {
    .contact-section {
      padding: 7rem 0 8rem;
    }
  }

  .contact-bg-number {
    position: absolute;
    top: -0.5rem;
    right: -2rem;
    font-size: clamp(10rem, 22vw, 22rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    color: rgba(255, 255, 255, 0.025);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    font-family: Georgia, serif;
  }

  .contact-bg-lines {
    position: absolute;
    inset: 0;
    display: flex;
    gap: 4rem;
    pointer-events: none;
    opacity: 0.04;
  }
  .contact-bg-line {
    display: block;
    width: 1px;
    height: 100%;
    background: #fff;
  }

  /* ═══════════════════════════════════════
     GRID
  ═══════════════════════════════════════ */
  .contact-grid {
    display: grid;
    gap: 3.5rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 4rem;
    }
  }

  /* ═══════════════════════════════════════
     LEFT — INFO
  ═══════════════════════════════════════ */
  .contact-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #ffdadb;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .contact-eyebrow__line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: #ffdadb;
    opacity: 0.6;
  }
  .contact-headline {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: #fff;
  }
  .contact-headline em {
    font-style: italic;
    color: #ffdadb;
  }

  .contact-description {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 178, 183, 0.85);
    max-width: 32ch;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 767px) {
    .contact-description {
      max-width: 100%;
    }
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
  }
  .contact-detail {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 218, 219, 0.8);
    font-size: 0.9rem;
  }
  .contact-detail__icon {
    font-size: 1.15rem;
    color: #ffdadb;
    opacity: 0.75;
  }
</style>
