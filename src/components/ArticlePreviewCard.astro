---
// Componente de preview de artículo - muestra imagen, autores, fecha, tipo y título
import type { ArticlePreview } from '../lib/contentful';
import { getArticleUrl, getArticleTypeSlug, formatShortDate, getAuthorInitials } from '../lib/contentful';
import ExpandableArticleTitle from './ExpandableArticleTitle.astro';

interface Props {
  article: ArticlePreview;
  variant?: 'default' | 'featured' | 'compact';
  class?: string;
}

const { article, variant = 'default', class: className = '' } = Astro.props;

const articleUrl = getArticleUrl(article);
const typeSlug = getArticleTypeSlug(article.articleType);
const formattedDate = formatShortDate(article.publishDate);
const authors = article.authorsCollection.items;
const titleRevealId = `${article.sys.id}-${variant}`;
---

{variant === 'featured' ? (
  <!-- Variante Featured: Card grande con imagen de fondo - Diseño Editorial -->
  <article
    class:list={[
      'group relative block overflow-hidden rounded-sm bg-[#1c1c14] transition-all duration-500',
      'aspect-[4/3] md:aspect-[16/9]',
      'shadow-xl hover:shadow-2xl hover:shadow-[#5E0B15]/20',
      className
    ]}
  >
    <a
      href={articleUrl}
      tabindex="-1"
      class="absolute inset-0 z-10 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[#fcfaec]"
    ></a>

    <!-- Imagen de fondo con efecto parallax sutil -->
    <div class="absolute inset-0 overflow-hidden">
      <img 
        src={article.coverImage.url} 
        alt={article.coverImage.title || article.title}
        class="absolute inset-0 w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:rotate-1"
        loading="lazy"
      />
    </div>
    
    <!-- Overlay gradiente mejorado con múltiples capas -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#1c1c14] via-[#1c1c14]/70 to-transparent opacity-90"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-[#5E0B15]/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    
    <!-- Decorative corner accent -->
    <div class="absolute top-0 right-0 w-32 h-32 overflow-hidden">
      <div class="absolute top-4 -right-12 w-40 h-8 bg-[#5E0B15] rotate-45 opacity-0 group-hover:opacity-100 transition-all duration-500 group-hover:translate-x-0 translate-x-4"></div>
    </div>
    
    <!-- Contenido -->
    <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10 text-white">
      <!-- Badge tipo de artículo con diseño mejorado -->
      <div class="mb-6">
        <span class:list={[
          'inline-flex items-center gap-2 px-4 py-2 rounded-sm text-xs font-label font-bold uppercase tracking-[0.15em] backdrop-blur-sm shadow-lg',
          typeSlug === 'estudiantes' 
            ? 'bg-[#fcfaec] text-[#5E0B15]' 
            : 'bg-[#5E0B15] text-white border border-white/20'
        ]}>
          <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
          {typeSlug === 'estudiantes' ? 'Estudiantes' : 'Invitados'}
        </span>
      </div>
      
      <!-- Titulo controlado para evitar desborde en destacados -->
      <div class="mb-6 max-w-[min(30rem,100%)]">
        <ExpandableArticleTitle
          id={titleRevealId}
          title={article.title}
          href={articleUrl}
          class="font-headline text-2xl md:text-3xl lg:text-4xl font-bold leading-tight text-white"
          linkClass="decoration-white/70 underline-offset-4 transition-colors duration-300 group-hover:text-[#fcfaec]"
          clampClass="line-clamp-2"
          minCharactersForTrigger={60}
          buttonClass="mt-1 h-9 w-9 border-white/15 bg-white/10 text-white/80 backdrop-blur-sm hover:border-white/30 hover:bg-white/15 hover:text-white"
          panelClass="border-white/10 bg-[#fcfaec]/95"
        />
      </div>
      
      <!-- Meta: fecha y autores con diseño editorial -->
      <div class="flex flex-wrap items-center gap-4 text-white/80">
        <div class="flex items-center gap-3">
          <div class="w-8 h-px bg-[#5E0B15]"></div>
          <time datetime={article.publishDate} class="font-label text-sm tracking-wider uppercase">
            {formattedDate}
          </time>
        </div>
        <span class="w-1 h-1 rounded-full bg-white/40"></span>
        <div class="flex items-center gap-3">
          <div class="flex -space-x-2">
            {authors.slice(0, 3).map((author) => (
              author.profilePicture ? (
                <img 
                  src={author.profilePicture.url}
                  alt={author.fullName}
                  class="w-7 h-7 rounded-full object-cover ring-2 ring-[#1c1c14]"
                />
              ) : (
                <span class="w-7 h-7 rounded-full bg-[#5E0B15] text-white text-[10px] font-bold flex items-center justify-center ring-2 ring-[#1c1c14]">
                  {getAuthorInitials(author.fullName)}
                </span>
              )
            ))}
          </div>
          <span class="font-label text-sm">
            {authors.length === 1 ? authors[0].fullName : `${authors.length} autores`}
          </span>
        </div>
      </div>
    </div>
  </article>
) : variant === 'compact' ? (
  <!-- Variante Compact: Para listas horizontales - Diseño refinado -->
  <article
    class:list={[
      'group relative flex gap-5 md:gap-8 py-6 transition-all duration-300',
      'border-b border-[#5E0B15]/10 hover:border-[#5E0B15]/30',
      'hover:bg-gradient-to-r hover:from-[#5E0B15]/[0.03] hover:to-transparent',
      'px-4 -mx-4 rounded-sm',
      className
    ]}
  >
    <a
      href={articleUrl}
      tabindex="-1"
      class="absolute inset-0 z-10 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[#5E0B15]"
    ></a>

    <!-- Imagen thumbnail con marco decorativo -->
    <div class="shrink-0 relative">
      <div class="w-28 h-28 md:w-36 md:h-36 overflow-hidden rounded-sm">
        <img 
          src={article.coverImage.url}
          alt={article.coverImage.title || article.title}
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110"
          loading="lazy"
        />
      </div>
      
      <!-- Decorative frame on hover -->
      <div class="absolute -inset-2 border-2 border-[#5E0B15]/0 group-hover:border-[#5E0B15]/20 rounded-sm transition-all duration-300 pointer-events-none"></div>
      
      <!-- Type indicator corner -->
      <div class:list={[
        'absolute -top-1 -left-1 w-4 h-4 rounded-br-sm',
        typeSlug === 'estudiantes' ? 'bg-[#5E0B15]' : 'bg-[#1c1c14]'
      ]}></div>
    </div>
    
    <!-- Contenido -->
    <div class="flex-grow flex flex-col justify-center min-w-0 py-1">
      <!-- Meta superior con línea decorativa -->
      <div class="flex flex-wrap items-center gap-3 mb-3">
        <span class:list={[
          'inline-flex items-center gap-1.5 px-3 py-1 rounded-sm text-[10px] font-label font-bold uppercase tracking-[0.1em]',
          typeSlug === 'estudiantes' 
            ? 'bg-[#5E0B15]/10 text-[#5E0B15]' 
            : 'bg-[#1c1c14] text-[#fcfaec]'
        ]}>
          {typeSlug === 'estudiantes' ? 'Estudiantes' : 'Invitados'}
        </span>
        <div class="w-6 h-px bg-[#5E0B15]/30"></div>
        <time datetime={article.publishDate} class="font-label text-xs text-[#1c1c14]/60 uppercase tracking-wider">
          {formattedDate}
        </time>
      </div>
      
      <!-- Titulo con boton discreto si el clamp oculta contenido -->
      <div class="mb-3 min-h-[3.6rem]">
        <ExpandableArticleTitle
          id={titleRevealId}
          title={article.title}
          href={articleUrl}
          class="font-headline text-xl md:text-2xl font-bold text-[#1c1c14] leading-snug transition-colors duration-300 group-hover:text-[#5E0B15]"
          linkClass="decoration-[#5E0B15]/45 underline-offset-4"
          clampClass="line-clamp-2"
          minCharactersForTrigger={52}
          buttonClass="mt-1 h-9 w-9 bg-[#fcfaec] text-[#5E0B15]/65"
        />
      </div>
      
      <!-- Autores con diseño mejorado -->
      <div class="flex items-center gap-3 text-[#1c1c14]/70">
        <div class="flex -space-x-1.5">
          {authors.slice(0, 2).map((author) => (
            author.profilePicture ? (
              <img 
                src={author.profilePicture.url}
                alt={author.fullName}
                class="w-6 h-6 rounded-full object-cover ring-2 ring-[#fcfaec]"
              />
            ) : (
              <span class="w-6 h-6 rounded-full bg-[#5E0B15] text-white text-[9px] font-bold flex items-center justify-center ring-2 ring-[#fcfaec]">
                {getAuthorInitials(author.fullName)}
              </span>
            )
          ))}
        </div>
        <span class="font-label text-sm">
          {authors.map(a => a.fullName).join(', ')}
        </span>
      </div>
    </div>
  </article>
) : (
  <!-- Variante Default: Card vertical estándar - Diseño editorial premium -->
  <article
    class:list={[
      'group relative block bg-white rounded-sm overflow-hidden transition-all duration-500',
      'shadow-lg hover:shadow-2xl hover:shadow-[#5E0B15]/15',
      'hover:-translate-y-2',
      'border border-[#5E0B15]/0 hover:border-[#5E0B15]/10',
      className
    ]}
  >
    <a
      href={articleUrl}
      tabindex="-1"
      class="absolute inset-0 z-10 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-[#5E0B15]"
    ></a>

    <!-- Imagen de portada con efectos -->
    <div class="relative aspect-[16/10] overflow-hidden bg-[#1c1c14]">
      <img 
        src={article.coverImage.url}
        alt={article.coverImage.title || article.title}
        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
        loading="lazy"
      />
      
      <!-- Overlay sutil en hover -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#1c1c14]/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      
      <!-- Badge tipo con diseño premium -->
      <div class="absolute top-4 left-4">
        <span class:list={[
          'inline-flex items-center gap-2 px-3 py-1.5 rounded-sm text-[10px] font-label font-bold uppercase tracking-[0.12em] shadow-md backdrop-blur-sm',
          typeSlug === 'estudiantes' 
            ? 'bg-[#fcfaec]/95 text-[#5E0B15]' 
            : 'bg-[#5E0B15]/95 text-white'
        ]}>
          <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
          {typeSlug === 'estudiantes' ? 'Estudiantes' : 'Invitados'}
        </span>
      </div>
      
      <!-- Decorative line -->
      <div class="absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r from-[#5E0B15] via-[#5E0B15]/50 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
    </div>
    
    <!-- Contenido con espaciado refinado -->
    <div class="p-6 md:p-8">
      <!-- Fecha con línea decorativa -->
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-px bg-[#5E0B15]/40 group-hover:w-12 group-hover:bg-[#5E0B15] transition-all duration-300"></div>
        <time datetime={article.publishDate} class="font-label text-xs text-[#1c1c14]/60 uppercase tracking-[0.15em]">
          {formattedDate}
        </time>
      </div>
      
      <!-- Titulo con mas aire visual y acceso al texto completo -->
      <div class="mb-6 min-h-[5.75rem]">
        <ExpandableArticleTitle
          id={titleRevealId}
          title={article.title}
          href={articleUrl}
          class="font-headline text-xl md:text-2xl font-bold text-[#1c1c14] leading-snug transition-colors duration-300 group-hover:text-[#5E0B15]"
          linkClass="decoration-[#5E0B15]/45 underline-offset-4"
          clampClass="line-clamp-3"
          minCharactersForTrigger={74}
        />
      </div>
      
      <!-- Autores con diseño sofisticado -->
      <div class="flex items-center gap-4 pt-5 border-t border-[#5E0B15]/10">
        <div class="flex -space-x-2">
          {authors.map((author) => (
            author.profilePicture ? (
              <div class="relative group/avatar">
                <img 
                  src={author.profilePicture.url}
                  alt={author.fullName}
                  class="w-10 h-10 rounded-full object-cover ring-2 ring-white shadow-sm transition-transform duration-300 group-hover/avatar:scale-110"
                />
              </div>
            ) : (
              <span class="w-10 h-10 rounded-full bg-gradient-to-br from-[#5E0B15] to-[#5E0B15]/80 text-white text-xs font-bold flex items-center justify-center ring-2 ring-white shadow-sm">
                {getAuthorInitials(author.fullName)}
              </span>
            )
          ))}
        </div>
        <div class="min-w-0 flex-grow">
          <p class="font-headline font-semibold text-sm text-[#1c1c14] truncate">
            {authors.map(a => a.fullName).join(', ')}
          </p>
          <p class="font-label text-xs text-[#1c1c14]/50 uppercase tracking-wider mt-0.5">
            {authors.length === 1 ? 'Autor' : 'Autores'}
          </p>
        </div>
        
        <!-- Subtle arrow -->
        <div class="shrink-0">
          <span class="material-symbols-outlined text-[#5E0B15]/40 group-hover:text-[#5E0B15] transition-colors duration-300">chevron_right</span>
        </div>
      </div>
    </div>
  </article>
)}
