---
// Publicaciones recientes en la página de inicio
// Datos de Contentful
import ArticlePreviewCard from './ArticlePreviewCard.astro';
import { getRecentArticles } from '../lib/contentful';

// Obtener los 3 artículos más recientes
const recentArticles = await getRecentArticles(3);
---

<section class="py-16 md:py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 md:mb-16 gap-4">
      <div class="max-w-xl">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-headline font-semibold text-[#5E0B15] mb-4">
          Publicaciones Recientes
        </h2>
        <p class="text-on-surface-variant font-body leading-relaxed">
          Artículos e investigaciones desarrollados por nuestros asociados y especialistas invitados, orientados al análisis crítico del Derecho del Trabajo y de la Seguridad Social frente a la realidad nacional peruana.
        </p>
      </div>
      <a 
        class="text-[#5E0B15] font-label font-bold flex items-center gap-2 group shrink-0" 
        href="/publicaciones"
      >
        Ver Todos los Artículos
        <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
    
    {recentArticles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {recentArticles.map((article, index) => (
          <ArticlePreviewCard 
            article={article} 
            variant={index === 0 ? 'default' : 'default'} 
          />
        ))}
      </div>
    ) : (
      <!-- Estado vacío si no hay artículos -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        <!-- Placeholder card 1 -->
        <div class="md:col-span-2 bg-surface-container p-6 md:p-10 rounded-xl">
          <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-0.5 text-[10px] font-label font-bold uppercase rounded-sm mb-4 md:mb-6 inline-block">
            Próximamente
          </span>
          <h3 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-[#5E0B15] mb-4 md:mb-6 leading-tight">
            Artículos de investigación en camino
          </h3>
          <p class="text-base md:text-lg text-on-surface-variant font-body mb-6 md:mb-8">
            Pronto podrás acceder a investigaciones académicas de alta calidad producidas por estudiantes e invitados de DETRA-UNT.
          </p>
          <div class="flex items-center gap-4 border-t border-outline-variant/30 pt-6">
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-secondary-container flex items-center justify-center">
              <span class="material-symbols-outlined text-on-secondary-container">school</span>
            </div>
            <div>
              <p class="font-label font-bold text-sm text-on-surface">DETRA-UNT</p>
              <p class="font-label text-xs text-on-surface-variant">Investigación Académica</p>
            </div>
          </div>
        </div>
        
        <!-- Placeholder cards 2 & 3 -->
        <div class="space-y-6 md:space-y-8">
          <div class="bg-surface-variant p-6 md:p-8 rounded-xl">
            <h4 class="text-xl md:text-2xl font-headline font-bold text-primary mb-4">
              Artículos de Estudiantes
            </h4>
            <p class="text-sm text-on-surface-variant font-body mb-6">
              Investigaciones realizadas por estudiantes destacados de nuestra facultad.
            </p>
            <span class="text-xs font-label font-bold text-primary-container">
              Próximamente
            </span>
          </div>
          <div class="bg-primary text-on-primary p-6 md:p-8 rounded-xl shadow-2xl shadow-primary/20">
            <span class="material-symbols-outlined text-3xl md:text-4xl mb-4">auto_stories</span>
            <h4 class="text-xl md:text-2xl font-headline font-bold mb-4">
              Artículos de Invitados
            </h4>
            <p class="text-sm text-on-primary/70 font-body">
              Contribuciones de académicos e investigadores invitados.
            </p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
