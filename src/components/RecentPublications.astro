---
// Publicaciones recientes en la página de inicio
// Datos de Contentful
import ArticlePreviewCard from './ArticlePreviewCard.astro';
import { getRecentArticles } from '../lib/contentful';

// Obtener los 3 artículos más recientes
const recentArticles = await getRecentArticles(3);
---

<section class="relative py-8 md:py-10 lg:py-12 bg-[#fcfaec] overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(#5E0B15 1px, transparent 1px), linear-gradient(90deg, #5E0B15 1px, transparent 1px); background-size: 60px 60px;"></div>
    
    <!-- Decorative circles -->
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-[#5E0B15]/[0.03] blur-3xl"></div>
    <div class="absolute -bottom-48 -left-24 w-80 h-80 rounded-full bg-[#5E0B15]/[0.02] blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-8">
    
    <!-- Header Section -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-12 md:mb-8 gap-8">
      
      <!-- Left side: Title and description -->
      <div class="max-w-2xl">
        <!-- Section label -->
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-px bg-[#5E0B15]"></div>
          <span class="text-xs font-label font-bold uppercase tracking-[0.25em] text-[#5E0B15]">
            Investigación Jurídica
          </span>
        </div>
        
        <!-- Main title -->
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-headline font-bold text-[#1c1c14] mb-6 leading-[1.1] tracking-tight">
          Publicaciones
          <span class="relative inline-block">
            <span class="relative z-10 text-[#5E0B15]">Recientes</span>
            <span class="absolute bottom-2 left-0 w-full h-3 bg-[#5E0B15]/10 -z-0"></span>
          </span>
        </h2>
        
        <!-- Description -->
        <p class="text-lg md:text-xl text-[#1c1c14]/70 font-body leading-relaxed">
          Artículos e investigaciones desarrollados por nuestros asociados y especialistas invitados, orientados al análisis crítico del Derecho del Trabajo y de la Seguridad Social.
        </p>
      </div>
      
      <!-- Right side: CTA button -->
      <a 
        href="/publicaciones"
        class="group relative inline-flex items-center gap-3 bg-[#5E0B15] text-white px-8 py-4 rounded-sm font-label font-bold text-sm overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-[#5E0B15]/25 shrink-0"
      >
        <!-- Button shine effect -->
        <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
        
        <span class="relative">Ver Todos los Artículos</span>
        <span class="relative material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform duration-300">arrow_forward</span>
      </a>
    </div>
    
    {recentArticles.length > 0 ? (
      <!-- Articles Grid with staggered animation -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {recentArticles.map((article, index) => (
          <div 
            class="opacity-0 animate-fade-in-up"
            style={`animation-delay: ${index * 150}ms; animation-fill-mode: forwards;`}
          >
            <ArticlePreviewCard 
              article={article} 
              variant={index === 0 ? 'default' : 'default'} 
            />
          </div>
        ))}
      </div>
    ) : (
      <!-- Estado vacío mejorado si no hay artículos -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
        
        <!-- Main featured placeholder -->
        <div class="lg:col-span-7 relative group">
          <div class="relative bg-white p-8 md:p-12 rounded-sm overflow-hidden border border-[#5E0B15]/10 shadow-lg hover:shadow-2xl transition-all duration-500">
            
            <!-- Decorative corner -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-[#5E0B15]/5 -translate-y-1/2 translate-x-1/2 rotate-45"></div>
            
            <!-- Badge -->
            <div class="relative mb-8">
              <span class="inline-flex items-center gap-2 bg-[#5E0B15] text-white px-4 py-2 rounded-sm text-xs font-label font-bold uppercase tracking-wider">
                <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
                Próximamente
              </span>
            </div>
            
            <!-- Content -->
            <h3 class="text-3xl md:text-4xl lg:text-5xl font-headline font-bold text-[#1c1c14] mb-6 leading-tight">
              Artículos de investigación 
              <span class="text-[#5E0B15]">en camino</span>
            </h3>
            
            <p class="text-lg md:text-xl text-[#1c1c14]/70 font-body mb-10 leading-relaxed max-w-xl">
              Pronto podrás acceder a investigaciones académicas de alta calidad producidas por estudiantes e invitados de DETRA-UNT.
            </p>
            
            <!-- Author section -->
            <div class="flex items-center gap-5 pt-8 border-t border-[#5E0B15]/15">
              <div class="relative">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#5E0B15] to-[#5E0B15]/80 flex items-center justify-center shadow-lg">
                  <span class="material-symbols-outlined text-white text-2xl">school</span>
                </div>
                <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-[#fcfaec] rounded-full flex items-center justify-center">
                  <span class="w-3 h-3 rounded-full bg-green-500 animate-pulse"></span>
                </div>
              </div>
              <div>
                <p class="font-headline font-bold text-lg text-[#1c1c14]">DETRA-UNT</p>
                <p class="font-label text-sm text-[#1c1c14]/60">Centro de Investigación Académica</p>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Side cards -->
        <div class="lg:col-span-5 flex flex-col gap-8">
          
          <!-- Students card -->
          <div class="group relative flex-1 bg-white p-8 rounded-sm border border-[#5E0B15]/10 hover:border-[#5E0B15]/30 transition-all duration-300 hover:shadow-xl overflow-hidden">
            <!-- Hover gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#5E0B15]/0 to-[#5E0B15]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="relative">
              <!-- Icon -->
              <div class="w-12 h-12 rounded-sm bg-[#5E0B15]/10 flex items-center justify-center mb-6 group-hover:bg-[#5E0B15] transition-colors duration-300">
                <span class="material-symbols-outlined text-[#5E0B15] group-hover:text-white transition-colors duration-300 text-2xl">edit_note</span>
              </div>
              
              <h4 class="text-2xl font-headline font-bold text-[#1c1c14] mb-3 group-hover:text-[#5E0B15] transition-colors duration-300">
                Artículos de Estudiantes
              </h4>
              
              <p class="text-[#1c1c14]/70 font-body leading-relaxed mb-6">
                Investigaciones realizadas por estudiantes destacados de nuestra facultad.
              </p>
              
              <div class="flex items-center gap-2 text-[#5E0B15]">
                <span class="font-label font-bold text-sm">Próximamente</span>
                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform duration-300">arrow_forward</span>
              </div>
            </div>
          </div>
          
          <!-- Guests card (featured) -->
          <div class="group relative flex-1 bg-[#5E0B15] p-8 rounded-sm overflow-hidden shadow-2xl shadow-[#5E0B15]/30 hover:shadow-[#5E0B15]/50 transition-all duration-500">
            <!-- Decorative pattern -->
            <div class="absolute inset-0 opacity-10">
              <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
            </div>
            
            <!-- Glow effect -->
            <div class="absolute top-0 right-0 w-48 h-48 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            
            <div class="relative">
              <!-- Icon -->
              <div class="w-12 h-12 rounded-sm bg-white/20 flex items-center justify-center mb-6 backdrop-blur-sm">
                <span class="material-symbols-outlined text-white text-2xl">auto_stories</span>
              </div>
              
              <h4 class="text-2xl font-headline font-bold text-white mb-3">
                Artículos de Invitados
              </h4>
              
              <p class="text-white/80 font-body leading-relaxed mb-6">
                Contribuciones de académicos e investigadores especializados en derecho laboral.
              </p>
              
              <div class="flex items-center gap-2 text-white/90">
                <span class="font-label font-bold text-sm">Próximamente</span>
                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform duration-300">arrow_forward</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
    
    <!-- Bottom decorative element -->
    <div class="mt-8 md:mt-10 flex justify-center">
      <div class="flex items-center gap-6">
        <div class="w-16 md:w-24 h-px bg-gradient-to-r from-transparent to-[#5E0B15]/30"></div>
        <div class="w-2 h-2 rotate-45 bg-[#5E0B15]/40"></div>
        <div class="w-16 md:w-24 h-px bg-gradient-to-l from-transparent to-[#5E0B15]/30"></div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out;
  }
</style>
