<section class="mb-20 md:mb-32">
  <div class="text-justify grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
    <!-- Mission -->
    <div class="md:col-span-2 bg-[#f6f4e6] p-8 md:p-12 rounded-xl flex flex-col justify-between">
      <div>
        <h2 class="font-bold text-2xl md:text-3xl text-[#2e0007] mb-4 md:mb-6">Nuestra Misión</h2>
        <p class="text-base md:text-xl font-body text-[#564243] max-w-2xl leading-relaxed">
          Promover un espacio de reflexión, análisis e investigación para profundizar en el conocimiento del Derecho del Trabajo y de la Seguridad Social , formando estudiantes universitarios con una perspectiva crítica y un firme compromiso social que les permita analizar la realidad nacional y plantear alternativas de solución concretas frente a la problemática socio-laboral.
        </p>
      </div>
      <div class="mt-8 md:mt-12">
        <span class="material-symbols-outlined text-3xl md:text-4xl text-[#2e0007]/40">menu_book</span>
      </div>
    </div>
    
    <!-- Vision -->
    <div class="bg-[#550015] p-8 md:p-12 rounded-xl text-white flex flex-col justify-between">
      <div>
        <h2 class="font-bold text-2xl md:text-3xl mb-4 md:mb-6 font-headline">Nuestra Visión</h2>
        <p class="font-body opacity-90 leading-relaxed text-sm md:text-base">
          Trascender como una organización académica de alcance social que logre sentar las bases de un nuevo enfoque crítico del Derecho del Trabajo , impulsando la transformación del orden jurídico laboral hacia un modelo verdaderamente útil que atienda las necesidades de la clase trabajadora y contribuya al progreso material y al bienestar colectivo de la sociedad peruana.
        </p>
      </div>
      <div class="mt-8 md:mt-12 flex justify-end">
        <span class="material-symbols-outlined text-3xl md:text-4xl text-white/40" style="font-variation-settings: 'FILL' 1;">
          visibility
        </span>
      </div>
    </div>
  </div>
</section>
