---
/**
 * HighlightedMoments.astro
 * Componente de collage para mostrar momentos destacados del círculo.
 * Muestra hasta 6 imágenes en un layout asimétrico con modal para ver más.
 */
import { getMomentosDestacados, formatDateBySize } from '../lib/contentful';
import type { MomentoDestacado } from '../lib/contentful';

// Obtener todos los momentos para el modal y solo mostrar 6 en el collage principal
const allMomentos = await getMomentosDestacados();
const displayMomentos = allMomentos.slice(0, 6);
const hasMoreMomentos = allMomentos.length > 6;
const totalMomentos = allMomentos.length;
---

{displayMomentos.length > 0 && (
  <section class="py-12 md:py-20 bg-[#fcfaec] relative overflow-hidden">
    <!-- Patrón decorativo de fondo -->
    <div class="absolute inset-0 opacity-[0.04]">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-pattern" patternUnits="userSpaceOnUse" width="60" height="60">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#2e0007" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-pattern)"/>
      </svg>
    </div>

    <div class="max-w-[1400px] mx-auto px-4 md:px-6 lg:px-8 relative z-10">
      <!-- Header -->
      <div class="text-center mb-8 md:mb-12">
        <span class="inline-block px-4 py-1.5 bg-[#2e0007] text-[#ffdadb] text-xs font-label font-bold uppercase tracking-[0.2em] rounded-full mb-4">
          Galería
        </span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-headline font-bold text-[#2e0007] mb-4">
          Momentos Destacados
        </h2>
        <div class="h-1 w-24 bg-[#2e0007] mx-auto"></div>
        <p class="text-[#564243] font-body mt-4 max-w-xl mx-auto text-sm md:text-base">
          Revive los momentos más significativos de nuestro círculo de estudios
        </p>
      </div>

      <!-- Collage Grid - Más ancho y mejor distribuido -->
      <div class="grid grid-cols-2 md:grid-cols-12 gap-2 md:gap-3 lg:gap-4">
        {displayMomentos.map((momento, index) => {
          // Definir clases de grid según posición
          const gridClasses = [
            'col-span-2 md:col-span-5 row-span-1 md:row-span-2 aspect-[4/3] md:aspect-auto md:h-[420px]', // Grande izquierda
            'col-span-1 md:col-span-4 aspect-square md:aspect-auto md:h-[200px]', // Mediano arriba centro
            'col-span-1 md:col-span-3 aspect-square md:aspect-auto md:h-[200px]', // Mediano arriba derecha
            'col-span-1 md:col-span-4 aspect-square md:aspect-auto md:h-[200px]', // Abajo centro-izq
            'col-span-1 md:col-span-3 aspect-square md:aspect-auto md:h-[200px]', // Abajo centro-der
            'col-span-2 md:col-span-5 aspect-[16/9] md:aspect-auto md:h-[200px]', // Ancho abajo
          ];
          
          const isPrimary = index === 0;
          
          return (
            <article 
              class={`group relative rounded-xl md:rounded-2xl overflow-hidden cursor-pointer momento-card bg-[#eae9db] ${gridClasses[index] || 'col-span-1 aspect-square'}`}
              data-momento-index={index}
              role="button"
              tabindex="0"
              aria-label={`Ver momento: ${momento.description}`}
            >
              <!-- Imagen -->
              <img
                src={`${momento.imagen.url}?w=${isPrimary ? 1000 : 600}&h=${isPrimary ? 800 : 500}&fit=fill&fm=webp&q=85`}
                alt={momento.imagen.title || momento.description}
                class="absolute inset-0 w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-105"
                loading={index < 2 ? 'eager' : 'lazy'}
                decoding="async"
              />
              
              <!-- Overlay gradiente -->
              <div class={`absolute inset-0 bg-gradient-to-t from-[#2e0007]/90 via-[#2e0007]/20 to-transparent opacity-70 group-hover:opacity-85 transition-opacity duration-500`}></div>
              
              <!-- Contenido -->
              <div class="absolute inset-0 flex flex-col justify-end p-3 md:p-4 lg:p-5">
                <div class="transform translate-y-1 group-hover:translate-y-0 transition-transform duration-500">
                  {isPrimary && (
                    <span class="hidden md:inline-block px-2 py-0.5 bg-[#ffdadb] text-[#2e0007] text-[10px] font-label font-bold uppercase tracking-wider rounded mb-2">
                      Destacado
                    </span>
                  )}
                  <time 
                    datetime={momento.fecha}
                    class="block text-[#ffdadb] text-[10px] md:text-xs font-label font-medium uppercase tracking-wider mb-1"
                  >
                    {formatDateBySize(momento.fecha, 'short')}
                  </time>
                  <p class={`text-white font-body leading-snug line-clamp-2 ${isPrimary ? 'text-sm md:text-base lg:text-lg' : 'text-xs md:text-sm'}`}>
                    {momento.description}
                  </p>
                </div>
                
                <!-- Indicador de expandir -->
                <div class="absolute top-2 right-2 md:top-3 md:right-3 opacity-0 group-hover:opacity-100 transition-all duration-300 transform scale-75 group-hover:scale-100">
                  <span class="flex items-center justify-center w-8 h-8 md:w-10 md:h-10 bg-white/90 backdrop-blur-sm rounded-full shadow-lg">
                    <svg class="w-4 h-4 md:w-5 md:h-5 text-[#2e0007]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                    </svg>
                  </span>
                </div>
              </div>
              
              <!-- Borde decorativo en hover -->
              <div class="absolute inset-0 border-2 border-white/0 group-hover:border-white/40 rounded-xl md:rounded-2xl transition-all duration-500 pointer-events-none"></div>
            </article>
          );
        })}
      </div>

      <!-- Botón para ver más -->
      {hasMoreMomentos && (
        <div class="text-center mt-8 md:mt-10">
          <button 
            id="openGalleryModal"
            class="group inline-flex items-center gap-3 px-6 py-3 bg-[#2e0007] text-white rounded-full font-label font-bold text-sm uppercase tracking-wider hover:bg-[#550015] transition-all duration-300 shadow-lg hover:shadow-xl"
          >
            <span>Ver todos los momentos</span>
            <span class="flex items-center justify-center w-6 h-6 bg-white/20 rounded-full">
              <span class="text-xs">{totalMomentos}</span>
            </span>
            <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </div>
      )}
    </div>

    <!-- Modal Gallery -->
    <div 
      id="momentosGalleryModal" 
      class="fixed inset-0 z-50 hidden"
      role="dialog"
      aria-modal="true"
      aria-labelledby="modalTitle"
    >
      <!-- Backdrop -->
      <div class="absolute inset-0 bg-black/95 backdrop-blur-md" id="modalBackdrop"></div>
      
      <!-- Modal Content -->
      <div class="relative h-full flex flex-col">
        <!-- Header -->
        <header class="flex items-center justify-between p-4 md:p-6 border-b border-white/10">
          <div>
            <h3 id="modalTitle" class="text-xl md:text-2xl font-headline font-bold text-white">
              Momentos Destacados
            </h3>
            <p class="text-white/60 text-sm font-body mt-1">
              <span id="currentImageIndex">1</span> de {totalMomentos}
            </p>
          </div>
          <button 
            id="closeModal"
            class="flex items-center justify-center w-10 h-10 md:w-12 md:h-12 bg-white/10 hover:bg-white/20 rounded-full transition-colors"
            aria-label="Cerrar galería"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </header>

        <!-- Main Image Area -->
        <div class="flex-1 flex items-center justify-center p-4 md:p-8 relative overflow-hidden">
          <!-- Navigation Buttons -->
          <button 
            id="prevImage"
            class="absolute left-2 md:left-6 z-10 flex items-center justify-center w-10 h-10 md:w-14 md:h-14 bg-white/10 hover:bg-white/20 rounded-full transition-all hover:scale-110"
            aria-label="Imagen anterior"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </button>
          
          <button 
            id="nextImage"
            class="absolute right-2 md:right-6 z-10 flex items-center justify-center w-10 h-10 md:w-14 md:h-14 bg-white/10 hover:bg-white/20 rounded-full transition-all hover:scale-110"
            aria-label="Siguiente imagen"
          >
            <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>

          <!-- Image Container -->
          <div class="max-w-5xl w-full mx-auto">
            <figure class="relative">
              <img 
                id="modalMainImage"
                src=""
                alt=""
                class="w-full max-h-[55vh] md:max-h-[60vh] object-contain rounded-lg shadow-2xl transition-opacity duration-300"
              />
              <figcaption class="mt-4 md:mt-6 text-center">
                <time id="modalImageDate" class="block text-[#ffdadb] text-sm font-label font-medium uppercase tracking-wider mb-2"></time>
                <p id="modalImageDescription" class="text-white text-base md:text-lg lg:text-xl font-body max-w-2xl mx-auto"></p>
              </figcaption>
            </figure>
          </div>
        </div>

        <!-- Thumbnails -->
        <div class="border-t border-white/10 p-3 md:p-4 overflow-x-auto">
          <div id="thumbnailsContainer" class="flex gap-2 md:gap-3 justify-center min-w-max px-4">
            {allMomentos.map((momento, index) => (
              <button
                class="thumbnail-btn relative w-14 h-14 md:w-18 md:h-18 lg:w-20 lg:h-20 rounded-lg overflow-hidden opacity-40 hover:opacity-90 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-[#ffdadb] flex-shrink-0"
                data-index={index}
                data-url={momento.imagen.url}
                data-description={momento.description}
                data-date={momento.fecha}
                aria-label={`Ver imagen ${index + 1}: ${momento.description}`}
              >
                <img
                  src={`${momento.imagen.url}?w=160&h=160&fit=fill&fm=webp&q=75`}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                <div class="absolute inset-0 border-2 border-transparent thumbnail-border rounded-lg transition-colors"></div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

<style>
  /* Animaciones para el collage */
  .momento-card {
    animation: fadeInUp 0.6s ease-out both;
  }
  
  .momento-card:nth-child(1) { animation-delay: 0.05s; }
  .momento-card:nth-child(2) { animation-delay: 0.1s; }
  .momento-card:nth-child(3) { animation-delay: 0.15s; }
  .momento-card:nth-child(4) { animation-delay: 0.2s; }
  .momento-card:nth-child(5) { animation-delay: 0.25s; }
  .momento-card:nth-child(6) { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Modal visible state */
  #momentosGalleryModal.active {
    display: flex !important;
    animation: fadeIn 0.25s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Active thumbnail */
  .thumbnail-btn.active {
    opacity: 1 !important;
  }

  .thumbnail-btn.active .thumbnail-border {
    border-color: #ffdadb !important;
  }

  /* Image transition in modal */
  #modalMainImage.loading {
    opacity: 0.3;
  }

  /* Scrollbar styling for thumbnails */
  #thumbnailsContainer::-webkit-scrollbar {
    height: 6px;
  }

  #thumbnailsContainer::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
  }

  #thumbnailsContainer::-webkit-scrollbar-thumb {
    background: rgba(255, 218, 219, 0.4);
    border-radius: 3px;
  }

  #thumbnailsContainer::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 218, 219, 0.6);
  }

  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Thumbnails responsive size */
  @media (min-width: 768px) {
    .md\:w-18 { width: 4.5rem; }
    .md\:h-18 { height: 4.5rem; }
  }
</style>

<script>
  // Gallery Modal Controller - Ejecuta después de que el DOM esté listo
  function initGallery() {
    const modal = document.getElementById('momentosGalleryModal');
    const openBtn = document.getElementById('openGalleryModal');
    const closeBtn = document.getElementById('closeModal');
    const backdrop = document.getElementById('modalBackdrop');
    const prevBtn = document.getElementById('prevImage');
    const nextBtn = document.getElementById('nextImage');
    const mainImage = document.getElementById('modalMainImage') as HTMLImageElement | null;
    const imageDate = document.getElementById('modalImageDate');
    const imageDescription = document.getElementById('modalImageDescription');
    const currentIndexEl = document.getElementById('currentImageIndex');
    const thumbnails = document.querySelectorAll('.thumbnail-btn');
    const momentoCards = document.querySelectorAll('.momento-card');

    if (!modal || !mainImage) return;

    let currentIndex = 0;
    const totalImages = thumbnails.length;

    // Update modal with current image
    function updateModalImage(index: number) {
      const thumbnail = thumbnails[index] as HTMLElement;
      if (!thumbnail) return;

      const url = thumbnail.dataset.url || '';
      const description = thumbnail.dataset.description || '';
      const date = thumbnail.dataset.date || '';

      mainImage.classList.add('loading');
      
      // Preload image
      const img = new Image();
      img.onload = () => {
        mainImage.src = `${url}?w=1400&h=1000&fit=fill&fm=webp&q=90`;
        mainImage.alt = description;
        mainImage.classList.remove('loading');
      };
      img.src = `${url}?w=1400&h=1000&fit=fill&fm=webp&q=90`;

      // Format date
      if (date && imageDate) {
        const dateObj = new Date(date);
        imageDate.textContent = dateObj.toLocaleDateString('es-PE', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      }

      if (imageDescription) {
        imageDescription.textContent = description;
      }
      
      if (currentIndexEl) {
        currentIndexEl.textContent = String(index + 1);
      }

      // Update thumbnail active states
      thumbnails.forEach((thumb, i) => {
        thumb.classList.toggle('active', i === index);
      });

      // Scroll thumbnail into view
      thumbnail.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

      currentIndex = index;
    }

    // Open modal
    function openModal(startIndex = 0) {
      document.body.style.overflow = 'hidden';
      modal.classList.add('active');
      updateModalImage(startIndex);
    }

    // Close modal
    function closeModal() {
      document.body.style.overflow = '';
      modal.classList.remove('active');
    }

    // Navigate
    function goToNext() {
      const nextIndex = (currentIndex + 1) % totalImages;
      updateModalImage(nextIndex);
    }

    function goToPrev() {
      const prevIndex = (currentIndex - 1 + totalImages) % totalImages;
      updateModalImage(prevIndex);
    }

    // Event listeners
    if (openBtn) {
      openBtn.addEventListener('click', () => openModal(0));
    }
    
    if (closeBtn) {
      closeBtn.addEventListener('click', closeModal);
    }
    
    if (backdrop) {
      backdrop.addEventListener('click', closeModal);
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', goToPrev);
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', goToNext);
    }

    // Open modal from collage cards
    momentoCards.forEach((card) => {
      card.addEventListener('click', () => {
        const index = parseInt((card as HTMLElement).dataset.momentoIndex || '0');
        openModal(index);
      });
      
      // Keyboard support for cards
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          const index = parseInt((card as HTMLElement).dataset.momentoIndex || '0');
          openModal(index);
        }
      });
    });

    // Thumbnail clicks
    thumbnails.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = parseInt((thumb as HTMLElement).dataset.index || '0');
        updateModalImage(index);
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (!modal.classList.contains('active')) return;

      switch (e.key) {
        case 'Escape':
          closeModal();
          break;
        case 'ArrowLeft':
          goToPrev();
          break;
        case 'ArrowRight':
          goToNext();
          break;
      }
    });

    // Touch/swipe support for mobile
    let touchStartX = 0;
    let touchEndX = 0;

    modal.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).changedTouches[0].screenX;
    }, { passive: true });

    modal.addEventListener('touchend', (e) => {
      touchEndX = (e as TouchEvent).changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;
      
      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          goToNext();
        } else {
          goToPrev();
        }
      }
    }
  }

  // Initialize on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }

  // Re-initialize on Astro page transitions (View Transitions)
  document.addEventListener('astro:page-load', initGallery);
</script>
