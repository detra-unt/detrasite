---
import { getArticles } from '../lib/contentful';

// Obtener conteo total de artículos
const { total } = await getArticles({ limit: 1 });
---

<header class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-20 lg:py-32">
  <div class="grid lg:grid-cols-12 gap-8 md:gap-12 items-end">
    <div class="lg:col-span-8">
      <p class="font-label text-xs uppercase tracking-[0.3em] text-primary mb-4">Artículos de Investigación</p>
      <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-8xl text-primary font-bold leading-none tracking-tighter mb-6 md:mb-8">
        Conocimiento <br /><span class="italic font-normal">en la Intersección.</span>
      </h1>
      <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">
        Explora artículos de investigación académica de estudiantes e invitados que abordan los desafíos contemporáneos del derecho y su intersección con la sociedad.
      </p>
    </div>
    <div class="lg:col-span-4 hidden lg:flex flex-col items-end gap-4 pb-4">
      <div class="text-right">
        <p class="font-headline text-4xl font-bold text-primary">{total}</p>
        <p class="font-label text-sm text-on-surface-variant">Artículos publicados</p>
      </div>
      <div class="w-full h-px bg-outline-variant/30"></div>
    </div>
  </div>
</header>
