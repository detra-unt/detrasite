---
import { getArticles } from '../lib/contentful';

// Obtener conteo total de artículos
const { total } = await getArticles({ limit: 1 });
---

<header class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-20 lg:py-32">
  <div class="grid lg:grid-cols-12 gap-8 md:gap-12 items-center">
    <div class="lg:col-span-7">
      <p class="font-label text-xs uppercase tracking-[0.3em] text-[#5E0B15] mb-4">PRODUCCIÓN ACADÉMICA Y EDITORIAL</p>
      <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-8xl text-[#5E0B15] font-bold leading-none tracking-tighter mb-6 md:mb-8">
        Artículos <br /><span class="italic font-normal">de Investigación.</span>
      </h1>
      <p class="font-body text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed">
        Explora nuestra producción editorial, donde miembros e invitados analizan la problemática socio-laboral peruana. A través de una perspectiva crítica, abordamos los desafíos del Derecho del Trabajo y de la Seguridad Social para plantear y difundir alternativas de solución.
      </p>
    </div>
    <div class="lg:col-span-5 flex flex-col gap-6 lg:items-end">
      <div class="w-full max-w-sm mx-auto lg:mx-0 lg:ml-auto">
        <p class="font-label text-xs uppercase tracking-[0.3em] text-[#5E0B15] mb-3 text-center lg:text-right">Conoce nuestra revista</p>
        <img
          src="/revista.png"
          alt="Portada de la revista"
          class="w-full rounded-sm "
        />
        <p class="font-label text-xs uppercase tracking-[0.25em] text-on-surface-variant mt-3 text-center lg:text-right">N° 01 | Año 01 | 2024</p>
      </div>
      <div class="w-full max-w-sm mx-auto lg:max-w-none lg:mx-0 flex flex-col items-center lg:items-end gap-4 pb-4">
        <div class="text-center lg:text-right">
          <p class="font-headline text-4xl font-bold text-[#5E0B15]">{total}</p>
          <p class="font-label text-sm text-on-surface-variant">Artículos publicados</p>
        </div>
        <div class="w-full h-px bg-outline-variant/30"></div>
      </div>
    </div>
  </div>
</header>
