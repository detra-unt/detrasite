---
// Publicaciones destacadas - datos vendran de Contentful
const featuredPublications = [
  {
    id: 1,
    year: 2024,
    title: "La Soberania de los Algoritmos: Supervision Judicial en la Era de la IA",
    excerpt: "Un analisis profundo de como los sistemas automatizados de toma de decisiones estan desafiando las nociones tradicionales del derecho administrativo y el debido proceso dentro del Tribunal de Justicia Europeo.",
    author: {
      initials: "RA",
      name: "Dr. Rowan Alestair",
      role: "Investigador Principal, Div. Etica Legal"
    }
  },
  {
    id: 2,
    title: "Revision Anual del Derecho Internacional",
    excerpt: "Accede a nuestra publicacion trimestral insignia con articulos revisados por pares de academicos legales globales."
  }
];
---

<section class="mb-16 md:mb-24">
  <h2 class="font-headline text-2xl md:text-3xl text-[#2e0007] font-bold mb-8 md:mb-10">Revistas Destacadas</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
    <!-- Featured Card 1 -->
    <div class="md:col-span-2 group relative overflow-hidden bg-white rounded-xl p-6 md:p-8 transition-all hover:ring-1 hover:ring-[#dcc0c1]/30">
      <div class="flex flex-col h-full justify-between">
        <div>
          <div class="flex items-center justify-between mb-6 md:mb-8">
            <span class="bg-[#ffdea5] text-[#261900] px-3 py-1 rounded text-[10px] font-label font-bold uppercase tracking-widest">
              Ano: {featuredPublications[0].year}
            </span>
            <span class="material-symbols-outlined text-[#897172]">article</span>
          </div>
          <h3 class="font-headline text-2xl md:text-3xl lg:text-4xl text-[#2e0007] font-bold leading-tight group-hover:text-[#550015] transition-colors mb-4">
            {featuredPublications[0].title}
          </h3>
          <p class="font-body text-[#564243] line-clamp-3 mb-6 md:mb-8 text-sm md:text-base">
            {featuredPublications[0].excerpt}
          </p>
        </div>
        <div class="flex items-center gap-4 border-t border-[#dcc0c1]/20 pt-6">
          <div class="w-10 h-10 rounded-full bg-[#fdcbce] flex items-center justify-center font-headline text-[#2e0007] font-bold text-sm">
            {featuredPublications[0].author.initials}
          </div>
          <div>
            <p class="font-label text-sm font-semibold text-[#1c1c14]">{featuredPublications[0].author.name}</p>
            <p class="font-label text-[11px] text-[#564243]">{featuredPublications[0].author.role}</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Featured Card 2 (Vertical Focus) -->
    <div class="md:col-span-1 bg-[#2e0007] text-white rounded-xl p-6 md:p-8 flex flex-col justify-between">
      <div>
        <div class="mb-6 md:mb-8">
          <span class="material-symbols-outlined text-[#ffdadb] text-3xl md:text-4xl">book</span>
        </div>
        <h3 class="font-headline text-xl md:text-2xl font-bold mb-4 italic">{featuredPublications[1].title}</h3>
        <p class="font-body text-[#ffdadb]/70 text-sm leading-relaxed mb-6">
          {featuredPublications[1].excerpt}
        </p>
      </div>
      <a class="flex items-center text-sm font-label group" href="#">
        Explorar Volumen 12
        <span class="material-symbols-outlined ml-2 group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
  </div>
</section>
