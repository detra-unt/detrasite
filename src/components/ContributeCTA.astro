---
// src/components/ContributeCTA.astro
---

<section class="ccta-root">
  <!-- Patrón decorativo de fondo -->
  <div class="ccta-pattern" aria-hidden="true"></div>

  <div class="ccta-container">
    <!-- Marco perimetral decorativo tipo certificado/editorial -->
    <div class="ccta-frame">
      <!-- Esquinas decorativas -->
      <div class="ccta-corner ccta-corner--tl" aria-hidden="true"></div>
      <div class="ccta-corner ccta-corner--tr" aria-hidden="true"></div>
      <div class="ccta-corner ccta-corner--bl" aria-hidden="true"></div>
      <div class="ccta-corner ccta-corner--br" aria-hidden="true"></div>

      <div class="ccta-content">
        <p class="ccta-eyebrow">
          <span
            class="material-symbols-outlined ccta-eyebrow__icon"
            style="font-variation-settings:'FILL' 1">history_edu</span
          >
          Convocatoria Abierta
          <span class="ccta-eyebrow__line"></span>
        </p>

        <h2 class="ccta-title">
          Publica en <br />
          <em>nuestro Blog.</em>
        </h2>

        <p class="ccta-description">
          Únete a nuestra prestigiosa red de académicos y profesionales
          aportando tu visión al Derecho del Trabajo y la Seguridad Social.
          Buscamos análisis rigurosos, perspectivas críticas y artículos de
          investigación inéditos para nuestra próxima edición impresa y portal
          digital.
        </p>

        <div class="ccta-actions">
          <!-- CTA Primario con el motifo 'colaboracion' hacia contacto -->
          <a
            href="/?motivo=colaboracion#contacto"
            class="ccta-btn ccta-btn--primary"
            data-astro-prefetch
          >
            <span class="ccta-btn__shimmer" aria-hidden="true"></span>
            <span class="ccta-btn__text">Presentar Propuesta de Artículo</span>
            <span class="ccta-btn__icon material-symbols-outlined"
              >arrow_forward</span
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ══════════════════════════════════════════
     RAÍZ Y FONDOS
  ══════════════════════════════════════════ */
  .ccta-root {
    position: relative;
    background: linear-gradient(180deg, #fcfaec 0%, #f5f2e3 100%);
    color: #2e0007;
    padding: 3rem 1rem;
    overflow: hidden;
    display: flex;
    justify-content: center;
  }
  @media (min-width: 768px) {
    .ccta-root {
      padding: 4rem 1.5rem;
    }
  }

  .ccta-pattern {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%232e0007' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    z-index: 0;
  }

  /* ══════════════════════════════════════════
     CONTENEDOR Y MARCO
  ══════════════════════════════════════════ */
  .ccta-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 52rem;
  }

  .ccta-frame {
    position: relative;
    padding: 2rem 1.25rem;
    border: 1px solid rgba(46, 0, 7, 0.12);
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.7) 0%,
      rgba(255, 255, 255, 0.3) 100%
    );
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 1rem;
    box-shadow: 
      0 4px 24px rgba(46, 0, 7, 0.06),
      0 1px 2px rgba(46, 0, 7, 0.04);
  }
  @media (min-width: 768px) {
    .ccta-frame {
      padding: 3rem 3.5rem;
      border-radius: 1.25rem;
    }
  }

  /* Esquinas decorativas del marco */
  .ccta-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid #2e0007;
    opacity: 0.25;
  }
  .ccta-corner--tl {
    top: -3px;
    left: -3px;
    border-right: none;
    border-bottom: none;
    border-radius: 4px 0 0 0;
  }
  .ccta-corner--tr {
    top: -3px;
    right: -3px;
    border-left: none;
    border-bottom: none;
    border-radius: 0 4px 0 0;
  }
  .ccta-corner--bl {
    bottom: -3px;
    left: -3px;
    border-right: none;
    border-top: none;
    border-radius: 0 0 0 4px;
  }
  .ccta-corner--br {
    bottom: -3px;
    right: -3px;
    border-left: none;
    border-top: none;
    border-radius: 0 0 4px 0;
  }

  /* ══════════════════════════════════════════
     CONTENIDO
  ══════════════════════════════════════════ */
  .ccta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ccta-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: #7a3a42;
    margin-bottom: 1.25rem;
  }
  .ccta-eyebrow__icon {
    font-size: 1rem;
    opacity: 0.85;
  }
  .ccta-eyebrow__line {
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
  }

  .ccta-title {
    font-family: "Newsreader", Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #2e0007;
    margin: 0 0 1.25rem;
  }
  .ccta-title em {
    font-style: italic;
    font-weight: 300;
    color: #7a3a42;
  }

  .ccta-description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #564243;
    max-width: 46ch;
    margin: 0 0 2rem;
  }
  @media (min-width: 768px) {
    .ccta-description {
      font-size: 1rem;
      margin: 0 0 2.5rem;
    }
  }

  /* ══════════════════════════════════════════
     ACCIONES Y BOTONES
  ══════════════════════════════════════════ */
  .ccta-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    align-items: center;
  }
  @media (min-width: 480px) {
    .ccta-actions {
      flex-direction: row;
      justify-content: center;
      width: auto;
    }
  }

  .ccta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.875rem 1.5rem;
    border-radius: 0.5rem;
    overflow: hidden;
    transition: all 0.3s ease;
    width: 100%;
  }
  @media (min-width: 480px) {
    .ccta-btn {
      width: auto;
      padding: 0.875rem 1.75rem;
    }
  }

  .ccta-btn--primary {
    background: #2e0007;
    color: #fcfaec;
    box-shadow: 
      0 2px 8px rgba(46, 0, 7, 0.15),
      0 1px 2px rgba(46, 0, 7, 0.1);
  }
  .ccta-btn--primary:hover {
    background: #550015;
    box-shadow: 
      0 4px 16px rgba(46, 0, 7, 0.2),
      0 2px 4px rgba(46, 0, 7, 0.12);
    transform: translateY(-2px);
  }

  .ccta-btn__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      transparent 20%,
      rgba(255, 255, 255, 0.25) 50%,
      transparent 80%
    );
    transform: translateX(-100%);
    transition: transform 0s;
    pointer-events: none;
  }
  .ccta-btn:hover .ccta-btn__shimmer {
    transform: translateX(100%);
    transition: transform 0.6s ease;
  }

  .ccta-btn__text {
    position: relative;
    z-index: 1;
  }
  .ccta-btn__icon {
    position: relative;
    z-index: 1;
    font-size: 1rem;
    transition: transform 0.3s ease;
  }
  .ccta-btn:hover .ccta-btn__icon {
    transform: translateX(3px);
  }
</style>
