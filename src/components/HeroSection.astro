<style>
  /* ─── Keyframes ─────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-32px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes drawRule {
    from { transform: scaleY(0); }
    to   { transform: scaleY(1); }
  }
  @keyframes drawCorner {
    from { width: 0; height: 0; }
    to   { width: 2.5rem; height: 2.5rem; }
  }
  @keyframes drawCornerH {
    from { width: 0; }
    to   { width: 2.5rem; }
  }
  @keyframes drawCornerV {
    from { height: 0; }
    to   { height: 2.5rem; }
  }
  @keyframes shimmerText {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-3px); }
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0) translateX(-50%); opacity: 1; }
    50%       { transform: translateY(6px) translateX(-50%); opacity: 0.5; }
  }
  @keyframes panelReveal {
    from { opacity: 0; transform: translateX(28px) scale(0.97); }
    to   { opacity: 1; transform: translateX(0) scale(1); }
  }
  @keyframes rotateIn {
    from { opacity: 0; transform: rotate(90deg) translateY(-20px); }
    to   { opacity: 1; transform: rotate(90deg) translateY(0); }
  }

  /* ─── Staggered entrance classes ────────────────────── */
  .h-badge       { animation: fadeIn    0.6s ease-out 0.1s both; }
  .h-rule        { transform-origin: top center; animation: drawRule 0.8s cubic-bezier(.22,1,.36,1) 0.3s both; }
  .h-line1       { animation: slideRight 0.9s cubic-bezier(.22,1,.36,1) 0.4s both; }
  .h-line2       { animation: slideRight 0.9s cubic-bezier(.22,1,.36,1) 0.55s both; }
  .h-desc        { animation: fadeUp   0.9s ease-out 0.75s both; }
  .h-cta-primary { animation: fadeUp   0.7s ease-out 0.95s both; }
  .h-cta-second  { animation: fadeUp   0.7s ease-out 1.05s both; }
  .h-panel       { animation: panelReveal 1.1s cubic-bezier(.22,1,.36,1) 0.3s both; }
  .h-ornament    { animation: fadeIn   1.2s ease-out 0.2s both; }
  .h-scroll-ind  { animation: scrollBounce 2s ease-in-out 2s infinite; }
  .h-vertical-tag{ animation: rotateIn 0.7s ease-out 1.2s both; }

  /* ─── Decorative rule (vertical timeline bar) ────────── */
  .hero-rule {
    width: 2px;
    background: linear-gradient(to bottom, #5E0B15, #5E0B15aa, transparent);
    border-radius: 2px;
  }

  /* ─── Pulsing dot on the rule ────────────────────────── */
  .rule-dot {
    width: 8px;
    height: 8px;
    background: #5E0B15;
    border-radius: 50%;
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 3px rgba(94,11,21,0.15);
  }

  /* ─── Photo panel ─────────────────────────────────────── */
  .photo-frame {
    position: relative;
    border: 1.5px solid rgba(94, 11, 21, 0.18);
    background: #1c1c14;
    overflow: hidden;
  }
  .photo-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    filter: grayscale(30%) contrast(1.05);
    transition: transform 0.7s cubic-bezier(.22,1,.36,1), filter 0.7s ease;
  }
  .photo-frame:hover img {
    transform: scale(1.04);
    filter: grayscale(0%) contrast(1.05);
  }

  /* Crimson corner accents */
  .corner-tl,
  .corner-br {
    position: absolute;
    z-index: 10;
    pointer-events: none;
  }
  .corner-tl {
    top: -1.5px; left: -1.5px;
    border-top: 3px solid #5E0B15;
    border-left: 3px solid #5E0B15;
    width: 2.5rem; height: 2.5rem;
    animation: fadeIn 0.5s ease-out 1.2s both;
  }
  .corner-br {
    bottom: -1.5px; right: -1.5px;
    border-bottom: 3px solid #5E0B15;
    border-right: 3px solid #5E0B15;
    width: 2.5rem; height: 2.5rem;
    animation: fadeIn 0.5s ease-out 1.4s both;
  }

  /* Photo gradient overlay for readability */
  .photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      rgba(28,28,20,0.6) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* Caption inside photo */
  .photo-caption {
    position: absolute;
    bottom: 1rem; left: 1rem; right: 1rem;
    z-index: 3;
    color: rgba(252,250,236,0.85);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-family: var(--font-label);
  }

  /* ─── § ornament ─────────────────────────────────────── */
  .legal-ornament {
    position: absolute;
    font-family: var(--font-headline);
    font-weight: 800;
    font-style: italic;
    line-height: 1;
    color: rgba(94, 11, 21, 0.045);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ─── Badge ──────────────────────────────────────────── */
  .hero-badge-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: #000;
    color: #fcfaec;
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
  .badge-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #5E0B15;
    animation: shimmerText 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ─── Title text second line (faded crimson) ─────────── */
  .title-line-2 {
    color: rgba(94, 11, 21, 0.55);
  }

  /* ─── CTA Buttons ─────────────────────────────────────── */
  .btn-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: #5E0B15;
    color: #fff;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 30px rgba(94,11,21,0.3);
  }
  .btn-primary::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .btn-primary:hover {
    background: #7a0e1c;
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(94,11,21,0.4);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: transparent;
    color: #5E0B15;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    border: 1.5px solid rgba(94,11,21,0.35);
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
  }
  .btn-secondary:hover {
    background: rgba(94,11,21,0.05);
    border-color: rgba(94,11,21,0.65);
    transform: translateY(-2px);
  }
  .btn-secondary svg,
  .btn-primary svg {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .btn-primary:hover svg,
  .btn-secondary:hover svg {
    transform: translateX(3px);
  }

  /* ─── Scroll indicator ───────────────────────────────── */
  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    opacity: 0.5;
    animation: scrollBounce 2s ease-in-out 2s infinite;
  }
  .scroll-indicator span {
    font-family: var(--font-label);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #5E0B15;
  }

  /* ─── Vertical side tag (desktop) ───────────────────── */
  .side-tag {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: rotate(90deg) translateX(-50%);
    transform-origin: right center;
    font-family: var(--font-label);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(94,11,21,0.35);
    white-space: nowrap;
    z-index: 5;
  }

  /* ─── Bottom rule ─────────────────────────────────────── */
  .bottom-rule {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(94,11,21,0.25) 40%, rgba(94,11,21,0.25) 60%, transparent);
  }

  /* ─── Grain overlay ──────────────────────────────────── */
  .grain-overlay {
    position: absolute; inset: 0;
    pointer-events: none;
    opacity: 0.025;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    z-index: 30;
  }
</style>

<section class="relative min-h-[calc(100dvh-80px)] flex flex-col justify-center items-center overflow-hidden bg-[#fcfaec]">

  <!-- Grain texture -->
  <div class="grain-overlay"></div>

  <!-- Large § ornament background -->
  <div class="legal-ornament h-ornament" style="font-size: clamp(18rem, 40vw, 36rem); top: 50%; right: -4%; transform: translateY(-52%); opacity: 0.04;">§</div>

  <!-- Main content grid -->
  <div class="relative z-10 max-w-7xl mx-auto w-full px-6 md:px-10 xl:px-8 py-10 md:py-14 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 lg:gap-12 items-center -mt-6 md:-mt-12 lg:-mt-16">

    <!-- ── LEFT: Content column ───────────────────────── -->
    <div class="md:col-span-7 lg:col-span-7 flex flex-col justify-center">

      <!-- Badge -->
      <div class="h-badge mb-7 md:mb-8">
        <span class="hero-badge-inner">
          <span class="badge-dot"></span>
          Círculo de Estudios DETRA – UNT
        </span>
      </div>

      <!-- Vertical rule + title group -->
      <div class="flex items-start gap-4 md:gap-5 mb-7 md:mb-8">
        <!-- Animated vertical rule -->
        <div class="hero-rule h-rule shrink-0 mt-1 self-stretch relative" style="min-height: 4rem;">
          <div class="rule-dot"></div>
        </div>

        <!-- Title -->
        <h1 class="font-headline font-bold italic leading-[1.05] tracking-[-0.03em] text-[#5E0B15]"
            style="font-size: clamp(1.3rem, 1rem + 2.5vw, 3.1rem);">
          <span class="h-line1 block whitespace-nowrap">
            Construyendo una visión crítica
          </span>
          <span class="h-line2 block title-line-2">
            del Derecho del Trabajo.
          </span>
        </h1>
      </div>

      <!-- Description -->
      <div class="h-desc mb-8 md:mb-10 max-w-xl">
        <p class="font-body text-[#1c1c14]/70 leading-relaxed text-base md:text-lg">
          Promoviendo la investigación jurídica y el análisis crítico de la 
          realidad nacional en el ámbito del Derecho del Trabajo y la Seguridad 
          Social. Buscamos impulsar un modelo útil que atienda las verdaderas 
          necesidades de la clase trabajadora.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a href="/publicaciones" class="h-cta-primary">
          <button class="btn-primary w-full sm:w-auto">
            Ver publicaciones
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </button>
        </a>
        <a href="/sobrenosotros" class="h-cta-second">
          <button class="btn-secondary w-full sm:w-auto">
            Sobre nosotros
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </a>
      </div>

    </div>

    <!-- ── RIGHT: Photo panel ─────────────────────────── -->
    <div class="md:col-span-5 lg:col-span-5 h-panel self-center md:self-stretch flex items-center">
      <div class="photo-frame w-full" style="height: clamp(280px, 50vh, 540px);">
        <!-- Corner accents -->
        <div class="corner-tl"></div>
        <div class="corner-br"></div>

        <!-- Photo -->
        <img
          src="/principalv2.jpeg"
          alt="Miembros del Círculo de Estudios DETRA - UNT"
          width="800"
          height="600"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />

        <!-- Gradient overlay -->
        <div class="photo-overlay"></div>

        <!-- Caption -->
        <p class="photo-caption">Miembros del C.E. DETRA · UNT</p>
      </div>
    </div>

  </div>

  <!-- Vertical side tag (desktop only) -->
  <div class="side-tag h-vertical-tag hidden lg:block">
    Derecho del Trabajo y Seguridad Social
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator hidden md:flex">
    <span>Explorar</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5E0B15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>

  <!-- Bottom rule -->
  <div class="bottom-rule"></div>

</section>
