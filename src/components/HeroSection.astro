---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/principalv2.jpeg';
---

<style>
  /* ─── Keyframes ─────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes slideRight {
    from { opacity: 0; transform: translateX(-32px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  @keyframes drawRule {
    from { transform: scaleY(0); }
    to   { transform: scaleY(1); }
  }
  @keyframes drawCorner {
    from { width: 0; height: 0; }
    to   { width: 2.5rem; height: 2.5rem; }
  }
  @keyframes drawCornerH {
    from { width: 0; }
    to   { width: 2.5rem; }
  }
  @keyframes drawCornerV {
    from { height: 0; }
    to   { height: 2.5rem; }
  }
  @keyframes shimmerText {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  @keyframes floatBadge {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-3px); }
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0) translateX(-50%); opacity: 1; }
    50%       { transform: translateY(6px) translateX(-50%); opacity: 0.5; }
  }
  @keyframes panelReveal {
    from { opacity: 0; transform: translateX(28px) scale(0.97); }
    to   { opacity: 1; transform: translateX(0) scale(1); }
  }
  @keyframes rotateIn {
    from { opacity: 0; transform: rotate(90deg) translateY(-20px); }
    to   { opacity: 1; transform: rotate(90deg) translateY(0); }
  }

  /* ─── Staggered entrance classes ────────────────────── */
  .h-badge       { animation: fadeIn    0.6s ease-out 0.1s both; }
  .h-rule        { transform-origin: top center; animation: drawRule 0.8s cubic-bezier(.22,1,.36,1) 0.3s both; }
  .h-line1       { animation: slideRight 0.9s cubic-bezier(.22,1,.36,1) 0.4s both; }
  .h-line2       { animation: slideRight 0.9s cubic-bezier(.22,1,.36,1) 0.55s both; }
  .h-desc        { animation: fadeUp   0.9s ease-out 0.75s both; }
  .h-cta-primary { animation: fadeUp   0.7s ease-out 0.95s both; }
  .h-cta-second  { animation: fadeUp   0.7s ease-out 1.05s both; }
  .h-panel       { animation: panelReveal 1.1s cubic-bezier(.22,1,.36,1) 0.3s both; }
  .h-ornament    { animation: fadeIn   1.2s ease-out 0.2s both; }
  .h-scroll-ind  { animation: scrollBounce 2s ease-in-out 2s infinite; }
  .h-vertical-tag{ animation: rotateIn 0.7s ease-out 1.2s both; }

  /* ─── Decorative rule (vertical timeline bar) ────────── */
  .hero-rule {
    width: 2px;
    background: linear-gradient(to bottom, #5E0B15, #5E0B15aa, transparent);
    border-radius: 2px;
  }

  /* ─── Pulsing dot on the rule ────────────────────────── */
  .rule-dot {
    width: 8px;
    height: 8px;
    background: #5E0B15;
    border-radius: 50%;
    position: absolute;
    top: -4px;
    left: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 0 3px rgba(94,11,21,0.15);
  }

  /* ─── Photo panel ─────────────────────────────────────── */
  /* The grid column must NOT overflow its allocated space */
  .photo-col {
    min-width: 0;
    min-height: 0;
    overflow: hidden;
  }
  .photo-frame {
    position: relative;
    border: 1.5px solid rgba(94, 11, 21, 0.18);
    background: #1c1c14;
    overflow: hidden;
    width: 100%;
    height: clamp(200px, 35vh, 370px);
    box-shadow: 0 10px 30px rgba(94, 11, 21, 0.05);
    transition: box-shadow 0.8s cubic-bezier(.22,1,.36,1), border-color 0.8s ease;
  }
  .photo-frame:hover {
    box-shadow: 0 20px 50px rgba(94, 11, 21, 0.2);
    border-color: rgba(94, 11, 21, 0.4);
  }
  .photo-frame:focus-visible {
    outline: 2px solid rgba(94, 11, 21, 0.75);
    outline-offset: 6px;
  }
  .photo-frame img {
    /* Fill the frame completely via absolute positioning to avoid intrinsic size overflow */
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(100%) contrast(1.15) brightness(0.9);
    transition: transform 0.8s cubic-bezier(.22,1,.36,1), filter 0.8s cubic-bezier(.22,1,.36,1);
  }
  .photo-frame:hover .hero-img,
  .photo-frame:focus-visible .hero-img {
    filter: grayscale(0%) contrast(1.05) brightness(1) !important;
    transform: scale(1.03) !important;
  }

  /* Crimson tint overlay to blend image with text color scheme */
  .photo-tint {
    position: absolute; inset: 0;
    background: #5E0B15;
    mix-blend-mode: soft-light;
    opacity: 0.8;
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.8s cubic-bezier(.22,1,.36,1);
  }
  .photo-frame:hover .photo-tint {
    opacity: 0;
  }

  /* Crimson corner accents */
  .corner-tl,
  .corner-br {
    position: absolute;
    z-index: 10;
    pointer-events: none;
    transition: width 0.7s cubic-bezier(.22,1,.36,1), height 0.7s cubic-bezier(.22,1,.36,1);
  }
  .corner-tl {
    top: -1.5px; left: -1.5px;
    border-top: 3px solid #5E0B15;
    border-left: 3px solid #5E0B15;
    width: 2.5rem; height: 2.5rem;
    animation: fadeIn 0.5s ease-out 1.2s both;
  }
  .corner-br {
    bottom: -1.5px; right: -1.5px;
    border-bottom: 3px solid #5E0B15;
    border-right: 3px solid #5E0B15;
    width: 2.5rem; height: 2.5rem;
    animation: fadeIn 0.5s ease-out 1.4s both;
  }
  .photo-frame:hover .corner-tl,
  .photo-frame:hover .corner-br {
    width: 4rem; height: 4rem;
  }

  /* Photo gradient overlay for readability */
  .photo-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      to top,
      rgba(28,28,20,0.7) 0%,
      rgba(28,28,20,0.1) 40%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.8s ease;
  }
  .photo-frame:hover .photo-overlay {
    opacity: 0.7; /* Slightly fade the gradient on hover so image pops more */
  }

  /* Caption inside photo */
  .photo-caption {
    position: absolute;
    bottom: 1.2rem; left: 1.5rem; right: 1.5rem;
    z-index: 3;
    color: rgba(252,250,236,0.85);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--font-label);
    transition: transform 0.7s cubic-bezier(.22,1,.36,1), color 0.7s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .photo-frame:hover .photo-caption {
    transform: translateY(-2px);
    color: #fcfaec;
  }
  .photo-caption::before {
    content: '';
    display: block;
    width: 15px;
    height: 1px;
    background: #5E0B15;
    transition: width 0.7s cubic-bezier(.22,1,.36,1), background 0.7s ease;
  }
  .photo-frame:hover .photo-caption::before {
    width: 30px;
    background: #fcfaec;
  }

  /* ─── Expand Icon ────────────────────────────────────── */
  .expand-icon {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.7s ease, transform 0.7s ease;
    margin-left: auto;
  }
  .photo-frame:hover .expand-icon {
    opacity: 1;
    transform: scale(1);
  }

  /* ─── Modal ──────────────────────────────────────────── */
  #image-modal[open] {
    animation: fadeIn 0.3s ease-out;
  }
  #image-modal::backdrop {
    background-color: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease-out;
  }

  /* ─── § ornament ─────────────────────────────────────── */
  .legal-ornament {
    position: absolute;
    font-family: var(--font-headline);
    font-weight: 800;
    font-style: italic;
    line-height: 1;
    color: rgba(94, 11, 21, 0.045);
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  /* ─── Badge ──────────────────────────────────────────── */
  .hero-badge-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: #000;
    color: #fcfaec;
    font-family: var(--font-label);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
  }
  .badge-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #5E0B15;
    animation: shimmerText 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ─── Title text second line (faded crimson) ─────────── */
  .title-line-2 {
    color: rgba(94, 11, 21, 0.55);
  }

  /* ─── CTA Buttons ─────────────────────────────────────── */
  .btn-primary {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: #5E0B15;
    color: #fff;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    border: none;
    cursor: pointer;
    transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
    box-shadow: 0 8px 30px rgba(94,11,21,0.3);
  }
  .btn-primary::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .btn-primary:hover {
    background: #7a0e1c;
    transform: translateY(-2px);
    box-shadow: 0 12px 36px rgba(94,11,21,0.4);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2rem;
    background: transparent;
    color: #5E0B15;
    font-family: var(--font-label);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    border: 1.5px solid rgba(94,11,21,0.35);
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
  }
  .btn-secondary:hover {
    background: rgba(94,11,21,0.05);
    border-color: rgba(94,11,21,0.65);
    transform: translateY(-2px);
  }
  .btn-secondary svg,
  .btn-primary svg {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .btn-primary:hover svg,
  .btn-secondary:hover svg {
    transform: translateX(3px);
  }

  /* ─── Scroll indicator ───────────────────────────────── */
  .scroll-indicator {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    opacity: 0.5;
    animation: scrollBounce 2s ease-in-out 2s infinite;
  }
  .scroll-indicator span {
    font-family: var(--font-label);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #5E0B15;
  }

  /* ─── Vertical side tag (desktop) ───────────────────── */
  .side-tag {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: rotate(90deg) translateX(-50%);
    transform-origin: right center;
    font-family: var(--font-label);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(94,11,21,0.35);
    white-space: nowrap;
    z-index: 5;
  }

  /* ─── Bottom rule ─────────────────────────────────────── */
  .bottom-rule {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(94,11,21,0.25) 40%, rgba(94,11,21,0.25) 60%, transparent);
  }

  /* ─── Grain overlay ──────────────────────────────────── */
  .grain-overlay {
    position: absolute; inset: 0;
    pointer-events: none;
    opacity: 0.025;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    z-index: 30;
  }
</style>

<section class="relative min-h-[calc(100dvh-80px)] flex flex-col justify-center items-center overflow-hidden bg-[#fcfaec]">

  <!-- Grain texture -->
  <div class="grain-overlay"></div>

  <!-- Large § ornament background -->
  <div class="legal-ornament h-ornament" style="font-size: clamp(18rem, 40vw, 36rem); top: 50%; right: -4%; transform: translateY(-52%); opacity: 0.04;">§</div>

  <!-- Main content grid -->
  <div class="relative z-10 max-w-7xl mx-auto w-full px-6 md:px-10 xl:px-8 py-10 md:py-14 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 lg:gap-12 items-center -mt-6 md:-mt-12 lg:-mt-16">

    <!-- ── LEFT: Content column ───────────────────────── -->
    <div class="md:col-span-7 lg:col-span-7 flex flex-col justify-center">

      <!-- Badge -->
      <div class="h-badge mb-7 md:mb-8">
        <span class="hero-badge-inner">
          <span class="badge-dot"></span>
          Círculo de Estudios DETRA – UNT
        </span>
      </div>

      <!-- Vertical rule + title group -->
      <div class="flex items-start gap-4 md:gap-5 mb-7 md:mb-8">
        <!-- Animated vertical rule -->
        <div class="hero-rule h-rule shrink-0 mt-1 self-stretch relative" style="min-height: 4rem;">
          <div class="rule-dot"></div>
        </div>

        <!-- Title -->
        <h1 class="font-headline font-bold italic leading-[1.05] tracking-[-0.03em] text-[#5E0B15]"
            style="font-size: clamp(1.3rem, 1rem + 2.5vw, 3.1rem);">
          <span class="h-line1 block whitespace-nowrap">
            Construyendo una visión crítica
          </span>
          <span class="h-line2 block title-line-2">
            del Derecho del Trabajo.
          </span>
        </h1>
      </div>

      <!-- Description -->
      <div class="h-desc mb-8 md:mb-10 max-w-xl">
        <p class="font-body text-[#1c1c14]/70 leading-relaxed text-base md:text-lg">
          Promoviendo la investigación jurídica y el análisis crítico de la 
          realidad nacional en el ámbito del Derecho del Trabajo y la Seguridad 
          Social. Buscamos impulsar un modelo útil que atienda las verdaderas 
          necesidades de la clase trabajadora.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
        <a href="/publicaciones" class="h-cta-primary btn-primary w-full sm:w-auto">
          Ver publicaciones
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="/sobrenosotros" class="h-cta-second btn-secondary w-full sm:w-auto">
          Sobre nosotros
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- ── RIGHT: Photo panel ─────────────────────────── -->
    <div class="md:col-span-5 lg:col-span-5 h-panel photo-col self-center flex items-center" style="min-width:0;overflow:hidden;">
      <div
        id="hero-photo"
        class="photo-frame cursor-pointer"
        title="Ver imagen ampliada"
        role="button"
        tabindex="0"
        aria-label="Ver imagen ampliada del Círculo de Estudios DETRA - UNT"
      >
        <!-- Corner accents -->
        <div class="corner-tl"></div>
        <div class="corner-br"></div>

        <!-- Photo -->
        <Image
          src={heroImage}
          alt="Miembros del Círculo de Estudios DETRA - UNT"
          widths={[400, 600, 800, 1200]}
          sizes="(max-width: 768px) 100vw, 40vw"
          format="webp"
          quality={90}
          fetchpriority="high"
          loading="eager"
          decoding="async"
          class="hero-img"
        />

        <!-- Crimson tint for duotone effect -->
        <div class="photo-tint"></div>

        <!-- Gradient overlay -->
        <div class="photo-overlay"></div>

        <!-- Caption -->
        <div class="photo-caption">
          <span>Miembros del C.E. DETRA · UNT</span>
          <svg class="expand-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
          </svg>
        </div>
      </div>
    </div>

  </div>

  <!-- Vertical side tag (desktop only) -->
  <div class="side-tag h-vertical-tag hidden lg:block">
    Derecho del Trabajo y Seguridad Social
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator hidden md:flex">
    <span>Explorar</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#5E0B15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>

  <!-- Bottom rule -->
  <div class="bottom-rule"></div>

</section>

<!-- Image Modal -->
<style>
  /* Full dialog styling: takes full viewport, centers content */
  #image-modal {
    position: fixed;
    inset: 0;
    display: none;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #image-modal[open] {
    display: flex;
  }
  #image-modal::backdrop {
    background: rgba(8, 5, 5, 0.92);
    backdrop-filter: blur(6px);
  }
  .modal-inner {
    position: relative;
    max-width: min(95vw, 1100px);
    max-height: 92vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }
  .modal-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
    padding: 0.45rem 1rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 2px;
    color: rgba(255,255,255,0.85);
    font-family: var(--font-label, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }
  .modal-close-btn:hover {
    background: rgba(94,11,21,0.7);
    border-color: #5E0B15;
    color: #fff;
  }
  .modal-img {
    width: 100%;
    height: auto;
    max-height: 82vh;
    object-fit: contain;
    display: block;
    border: 1px solid rgba(94,11,21,0.35);
    box-shadow: 0 0 60px rgba(0,0,0,0.6), 0 0 0 1px rgba(94,11,21,0.1);
  }
  /* Prevent body scroll when modal open */
  :global(body.modal-open) {
    overflow: hidden;
  }
</style>

<dialog id="image-modal">
  <div class="modal-inner">
    <button id="modal-close" type="button" class="modal-close-btn" aria-label="Cerrar modal">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
      Cerrar
    </button>
    <Image
      src={heroImage}
      alt="Miembros del C.E. DETRA · UNT"
      widths={[800, 1200, 1600, 2000]}
      sizes="95vw"
      format="webp"
      quality={92}
      loading="lazy"
      class="modal-img"
    />
  </div>
</dialog>

<script>
  // ── AbortController para limpieza de listeners de este componente ──
  let heroModalAbortController: AbortController | null = null;

  function initHeroModal() {
    // Limpiar event listeners viejos si existen
    if (heroModalAbortController) {
      heroModalAbortController.abort();
    }

    const photoFrame = document.getElementById('hero-photo');
    const modal = document.getElementById('image-modal') as HTMLDialogElement | null;
    const modalClose = document.getElementById('modal-close');

    // Si no estamos en una página con el hero, salir silenciosamente
    if (!photoFrame || !modal || !modalClose) return;

    // Crear nuevo controller para esta instancia
    heroModalAbortController = new AbortController();
    const { signal } = heroModalAbortController;

    function openModal() {
      if (modal && !modal.open) {
        modal.showModal();
        document.body.classList.add('modal-open');
      }
    }

    function closeModal() {
      if (modal && modal.open) {
        modal.close();
      }
      document.body.classList.remove('modal-open');
    }

    // Event listeners con signal para poder limpiarlos
    photoFrame.addEventListener('click', openModal, { signal });
    
    photoFrame.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openModal();
      }
    }, { signal });
    
    modalClose.addEventListener('click', closeModal, { signal });

    // Close on backdrop click (clicking outside modal-inner)
    modal.addEventListener('click', (e: MouseEvent) => {
      const inner = modal.querySelector('.modal-inner') as HTMLElement;
      if (inner) {
        const rect = inner.getBoundingClientRect();
        const outsideX = e.clientX < rect.left || e.clientX > rect.right;
        const outsideY = e.clientY < rect.top || e.clientY > rect.bottom;
        if (outsideX || outsideY) closeModal();
      }
    }, { signal });

    // Native dialog close event (Escape key)
    modal.addEventListener('close', () => {
      document.body.classList.remove('modal-open');
    }, { signal });
  }

  // Inicializar en carga de página (funciona con View Transitions)
  document.addEventListener('astro:page-load', initHeroModal);

  // Limpieza antes de swap (View Transitions)
  document.addEventListener('astro:before-swap', () => {
    // Asegurar que el modal esté cerrado y el body limpio antes de navegar
    const modal = document.getElementById('image-modal') as HTMLDialogElement | null;
    if (modal?.open) {
      modal.close();
    }
    document.body.classList.remove('modal-open');

    // Abortar listeners
    if (heroModalAbortController) {
      heroModalAbortController.abort();
      heroModalAbortController = null;
    }
  });
</script>
