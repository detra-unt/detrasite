---
// Lista de publicaciones - datos vendran de Contentful
const publications = [
  {
    id: 1,
    date: "Oct 2023",
    title: "Jurisdicciones Oceanicas y Aumento del Nivel del Mar: Una Nueva Frontera",
    authors: "Co-escrito por Prof. Lin Zhao & Dr. Marcus Vane",
    tags: ["PDF (2.4 MB)", "Revisado por Pares"],
    downloadIcon: "download"
  },
  {
    id: 2,
    date: "Ago 2023",
    title: "Paradigmas de Privacidad en Redes Descentralizadas",
    authors: "Por Sarah J. Kensington, LL.M.",
    tags: ["PDF (1.1 MB)", "Version Web"],
    downloadIcon: "open_in_new"
  },
  {
    id: 3,
    date: "Jun 2023",
    title: "Responsabilidad Corporativa en Danos Ambientales Transnacionales",
    authors: "Consorcio de Investigacion DETRA-UNT",
    tags: ["PDF (4.8 MB)"],
    downloadIcon: "download"
  }
];
---

<section class="lg:col-span-8">
  <h2 class="font-headline text-2xl md:text-3xl text-[#2e0007] font-bold mb-6 md:mb-8">Publicaciones Recientes</h2>
  <div class="space-y-0">
    {publications.map(pub => (
      <div class="group py-8 md:py-10 bg-[#fcfaec] border-b border-[#dcc0c1]/30 flex flex-col md:flex-row gap-4 md:gap-8 items-start hover:bg-[#f6f4e6] transition-colors px-4 -mx-4 rounded-lg">
        <div class="md:w-32 shrink-0 pt-1">
          <p class="font-label text-[11px] uppercase tracking-widest text-[#564243]/60">{pub.date}</p>
        </div>
        <div class="flex-grow">
          <h4 class="font-headline text-xl md:text-2xl text-[#2e0007] font-bold mb-2">{pub.title}</h4>
          <p class="font-body text-sm text-[#564243] mb-4">{pub.authors}</p>
          <div class="flex flex-wrap gap-2">
            {pub.tags.map(tag => (
              <span class="text-[10px] font-label px-2 py-0.5 rounded border border-[#dcc0c1] text-[#564243]">
                {tag}
              </span>
            ))}
          </div>
        </div>
        <div class="shrink-0 flex items-center md:self-center">
          <span class="material-symbols-outlined text-[#2e0007] opacity-0 group-hover:opacity-100 transition-opacity">
            {pub.downloadIcon}
          </span>
        </div>
      </div>
    ))}
  </div>
  
  <div class="mt-12 md:mt-16 flex justify-center">
    <button class="font-label text-sm font-semibold text-[#2e0007] py-3 px-8 border border-[#2e0007]/20 rounded-full hover:bg-[#550015] hover:text-white transition-all">
      Cargar Mas Archivos
    </button>
  </div>
</section>
