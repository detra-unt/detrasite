---
import { getActiveJuntaDirectiva } from '../lib/contentful';

const juntaDirectiva = await getActiveJuntaDirectiva();
const managmentYear  = juntaDirectiva?.managmentYear ?? null;
const foto           = juntaDirectiva?.fotoGeneral   ?? null;
---

<section class="junta-section">

  <!-- ── Header ── -->
  <div class="junta-header">
    <div>
      <h2 class="junta-title">
        Junta Directiva
        {managmentYear && <strong>{managmentYear}</strong>}
      </h2>
      <p class="junta-subtitle">Las mentes detrás de nuestra excelencia académica.</p>
    </div>
    <span class="junta-rule" aria-hidden="true"></span>
  </div>

  <!-- ── Photo or Placeholder ── -->
  {foto ? (
    <div class="junta-card" id="junta-card" data-src={foto.url} data-alt={foto.title ?? `Junta Directiva ${managmentYear}`} data-year={managmentYear ?? ''}>
      <img
        class="junta-img"
        src={foto.url}
        alt={foto.title ?? `Junta Directiva ${managmentYear}`}
        loading="lazy"
        decoding="async"
      />

      <!-- Hover reveal layer -->
      <div class="junta-veil" aria-hidden="true">
        <div class="junta-veil__inner">
          <span class="junta-veil__badge">
            {managmentYear && `Junta Directiva ${managmentYear}`}
          </span>
          <button class="junta-veil__btn" id="junta-open-trigger" type="button" aria-label={`Ver foto completa de la Junta Directiva ${managmentYear}`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 3 21 3 21 9"/>
              <polyline points="9 21 3 21 3 15"/>
              <line x1="21" y1="3" x2="14" y2="10"/>
              <line x1="3" y1="21" x2="10" y2="14"/>
            </svg>
            Ver foto completa
          </button>
        </div>
      </div>
    </div>
  ) : (
    <div class="junta-empty">
      <div class="junta-empty__icon" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <p class="junta-empty__title">Próximamente</p>
      <p class="junta-empty__body">La fotografía oficial de la Junta Directiva se publicará en breve.</p>
    </div>
  )}
</section>

<!-- ─────────────────────────────────────────
     MODAL — injected into <body> by script
     to escape any stacking-context trap.
───────────────────────────────────────── -->
<template id="junta-modal-tpl">
  <div id="junta-modal" role="dialog" aria-modal="true" aria-label="Junta Directiva" style="display:none">
    <div id="junta-modal-backdrop"></div>
    <div id="junta-modal-box">
      <button id="junta-modal-close" type="button" aria-label="Cerrar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <figure id="junta-modal-figure">
        <img id="junta-modal-img" src="" alt="" loading="eager" decoding="async" />
        <figcaption id="junta-modal-caption"></figcaption>
      </figure>
    </div>
  </div>
</template>

<script>
  function initJuntaModal() {
    // ── Inject modal into <body> once (escape stacking context) ──
    if (!document.getElementById('junta-modal')) {
      const tpl = document.getElementById('junta-modal-tpl') as HTMLTemplateElement | null;
      if (tpl) {
        document.body.appendChild(tpl.content.cloneNode(true));
      }
    }

    const modal    = document.getElementById('junta-modal') as HTMLElement | null;
    const backdrop = document.getElementById('junta-modal-backdrop') as HTMLElement | null;
    const closeBtn = document.getElementById('junta-modal-close') as HTMLElement | null;
    const modalImg = document.getElementById('junta-modal-img') as HTMLImageElement | null;
    const caption  = document.getElementById('junta-modal-caption') as HTMLElement | null;
    const trigger  = document.getElementById('junta-open-trigger');
    const card     = document.getElementById('junta-card');

    if (!modal || !backdrop || !closeBtn || !modalImg || !caption) return;

    function openModal() {
      if (!modal || !card || !modalImg || !caption || !closeBtn) return;
      const src  = card.dataset.src  ?? '';
      const alt  = card.dataset.alt  ?? '';
      const year = card.dataset.year ?? '';

      modalImg.src = src;
      modalImg.alt = alt;
      caption.textContent = year ? `Junta Directiva ${year}` : '';

      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => modal!.classList.add('jm-open'));
      closeBtn.focus();
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('jm-open');
      // Use a one-shot transition listener — but re-create it each time
      // so it always fires correctly after re-opens.
      const onEnd = () => {
        modal!.style.display = 'none';
        document.body.style.overflow = '';
      };
      modal.addEventListener('transitionend', onEnd, { once: true });
    }

    // Re-attach listeners by cloning nodes to remove any stale listeners
    // from previous navigations.
    const newTrigger = trigger?.cloneNode(true) as HTMLElement | null;
    if (trigger && newTrigger) trigger.replaceWith(newTrigger);

    const newClose = closeBtn.cloneNode(true) as HTMLElement;
    closeBtn.replaceWith(newClose);

    const newBackdrop = backdrop.cloneNode(true) as HTMLElement;
    backdrop.replaceWith(newBackdrop);

    // Resolve fresh references after cloning
    const freshClose    = document.getElementById('junta-modal-close');
    const freshBackdrop = document.getElementById('junta-modal-backdrop');
    const freshTrigger  = document.getElementById('junta-open-trigger');

    freshTrigger?.addEventListener('click',  openModal);
    freshBackdrop?.addEventListener('click', closeModal);
    freshClose?.addEventListener('click',   closeModal);
  }

  // Keyboard Escape — attach once per page lifetime via a guard flag on window.
  if (!(window as any).__juntaEscBound) {
    (window as any).__juntaEscBound = true;
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      const modal = document.getElementById('junta-modal');
      if (e.key === 'Escape' && modal?.classList.contains('jm-open')) {
        modal.classList.remove('jm-open');
        modal.addEventListener('transitionend', () => {
          modal.style.display = 'none';
          document.body.style.overflow = '';
        }, { once: true });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initJuntaModal);
  document.addEventListener('astro:page-load',  initJuntaModal);
</script>

<style>
  /* ══════════════════════════════════
     SECTION
  ══════════════════════════════════ */
  .junta-section {
    margin-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .junta-section { margin-bottom: 8rem; }
  }

  /* ══════════════════════════════════
     HEADER
  ══════════════════════════════════ */
  .junta-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .junta-header {
      flex-direction: row;
      align-items: flex-end;
      gap: 0;
      margin-bottom: 3rem;
    }
  }

  .junta-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    color: #2e0007;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .junta-subtitle {
    color: #564243;
    font-size: 0.95rem;
    margin: 0;
  }

  .junta-rule {
    display: none;
  }

  @media (min-width: 768px) {
    .junta-rule {
      display: block;
      flex: 1;
      height: 1px;
      background: rgba(220, 192, 193, 0.35);
      margin: 0 3rem;
    }
  }

  /* ══════════════════════════════════
     PHOTO CARD
  ══════════════════════════════════ */
  .junta-card {
    position: relative;
    width: 100%;
    /* Fixed aspect ratio — landscape framing */
    aspect-ratio: 16 / 7;
    border-radius: 1rem;
    overflow: hidden;
    background: #0d0003;
    box-shadow:
      0 0 0 1px rgba(46, 0, 7, 0.09),
      0 20px 60px rgba(46, 0, 7, 0.16),
      0 4px 14px rgba(46, 0, 7, 0.10);
    cursor: pointer;
  }

  /* ── The grayscale photo ── */
  .junta-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Show the bottom of the photo where people sit */
    object-position: center bottom;
    filter: grayscale(100%) brightness(0.9) contrast(1.08);
    transition:
      filter  0.75s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: filter, transform;
  }

  .junta-card:hover .junta-img {
    filter: grayscale(0%) brightness(1) contrast(1);
    transform: scale(1.025);
  }

  /* ── Hover veil overlay ── */
  .junta-veil {
    position: absolute;
    inset: 0;
    /* Bottom-weighted gradient */
    background: linear-gradient(
      to top,
      rgba(14, 0, 3, 0.80) 0%,
      rgba(14, 0, 3, 0.28) 40%,
      transparent 70%
    );
    display: flex;
    align-items: flex-end;
    opacity: 0;
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .junta-card:hover .junta-veil {
    opacity: 1;
  }

  .junta-veil__inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    gap: 1rem;
  }

  .junta-veil__badge {
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 222, 165, 0.88);
    font-weight: 700;
  }

  /* ── "Ver foto completa" button ── */
  .junta-veil__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 600;
    color: #1a0003;
    background: rgba(255, 222, 165, 0.92);
    border: none;
    border-radius: 2rem;
    cursor: pointer;
    white-space: nowrap;
    transform: translateY(6px);
    transition:
      background 0.2s ease,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .junta-card:hover .junta-veil__btn {
    transform: translateY(0);
  }

  .junta-veil__btn:hover {
    background: #ffdea5;
  }

  @media (max-width: 640px) {
    .junta-card {
      aspect-ratio: 4 / 3;
    }

    .junta-veil__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      padding: 1rem 1.1rem;
    }
  }

  /* ══════════════════════════════════
     PLACEHOLDER (no active junta)
  ══════════════════════════════════ */
  .junta-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    min-height: 260px;
    border-radius: 1rem;
    border: 1.5px dashed rgba(46, 0, 7, 0.15);
    background: rgba(234, 233, 219, 0.3);
    padding: 3rem 2rem;
    text-align: center;
  }

  .junta-empty__icon {
    color: rgba(86, 66, 67, 0.38);
  }

  .junta-empty__title {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: #2e0007;
    margin: 0;
  }

  .junta-empty__body {
    font-size: 0.875rem;
    color: #7a5153;
    max-width: 26rem;
    line-height: 1.7;
    margin: 0;
  }
</style>

<!--
  MODAL GLOBAL STYLES  
  These must live in a <style> tag that is NOT scoped,
  because the modal is appended to <body>, outside this component.
  We use is:global to opt out of Astro scoping.
-->
<style is:global>
  #junta-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 3.5rem 1rem 1rem;
    opacity: 0;
    transition: opacity 0.32s ease;
    overflow-y: auto;
  }

  #junta-modal.jm-open {
    opacity: 1;
  }

  #junta-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 0, 2, 0.90);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  #junta-modal-box {
    position: relative;
    z-index: 1;
    /* width: auto so the box shrinks to image width */
    width: auto;
    max-width: min(100%, 1200px);
    max-height: calc(100vh - 4.5rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateY(22px) scale(0.96);
    transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #junta-modal.jm-open #junta-modal-box {
    transform: translateY(0) scale(1);
  }

  #junta-modal-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 10001;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(10, 0, 2, 0.70);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  #junta-modal-close:hover {
    background: rgba(46, 0, 7, 0.88);
    border-color: rgba(255, 222, 165, 0.5);
    transform: scale(1.08);
  }

  #junta-modal-figure {
    margin: 0;
    border-radius: 0.875rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.06),
      0 40px 100px rgba(0,0,0,0.6);
    /* Hug the image — no extra width */
    display: inline-flex;
    flex-direction: column;
    line-height: 0;
    max-width: 100%;
  }

  #junta-modal-img {
    display: block;
    /* Let the image keep its natural width; only cap at container limit */
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: calc(100vh - 6rem);
    object-fit: contain;
    filter: none;
  }

  #junta-modal-caption {
    background: rgba(10, 0, 2, 0.88);
    color: rgba(255, 222, 165, 0.85);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    text-align: center;
  }

  #junta-modal-caption:empty {
    display: none;
  }
</style>
