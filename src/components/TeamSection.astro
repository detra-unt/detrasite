<section class="mb-20 md:mb-32">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 md:mb-16 gap-4">
    <div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl text-[#2e0007] mb-4">Junta Directiva <span class="font-bold">2026</span></h2>
      <p class="font-body text-[#564243]">Las mentes detras de nuestra excelencia academica.</p>
    </div>
    <div class="hidden md:block h-[1px] flex-grow mx-12 bg-[#dcc0c1]/30"></div>
    <button class="text-[#2e0007] font-bold font-label hover:underline text-sm">VER TODOS LOS MIEMBROS</button>
  </div>
  
  <!-- Team Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
    {teamMembers.map(member => (
      <div class="group">
        <div class="aspect-square bg-[#eae9db] rounded-xl mb-4 md:mb-6 overflow-hidden relative">
          <img 
            alt={`Retrato de ${member.name}`}
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
            src={member.image}
          />
          {member.badge && (
            <div class="absolute top-3 md:top-4 left-3 md:left-4">
              <span class="bg-[#ffdea5] text-[#261900] text-[9px] px-2 py-0.5 rounded-sm font-label uppercase tracking-tighter">
                {member.badge}
              </span>
            </div>
          )}
        </div>
        <h3 class="text-base md:text-xl text-[#2e0007] font-bold">{member.name}</h3>
        <p class="font-label text-[10px] md:text-xs text-[#564243] uppercase tracking-widest mt-1">{member.role}</p>
      </div>
    ))}
  </div>
</section>
