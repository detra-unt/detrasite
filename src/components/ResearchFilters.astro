---
// Categorias para filtrar publicaciones
// Estas categorias vendran de Contentful en el futuro
const categories = [
  { id: 'all', name: 'Toda la Investigacion', active: true },
  { id: 'constitutional', name: 'Derecho Constitucional', active: false },
  { id: 'digital', name: 'Gobernanza Digital', active: false },
  { id: 'environmental', name: 'Politica Ambiental', active: false },
  { id: 'human-rights', name: 'Derechos Humanos', active: false },
];
---

<section class="max-w-7xl mx-auto px-6 md:px-8 pb-10 md:pb-16">
  <div class="flex flex-wrap gap-2 md:gap-3">
    {categories.map(category => (
      <span 
        class:list={[
          "px-3 md:px-4 py-2 text-xs font-label rounded-full cursor-pointer transition-colors",
          category.active 
            ? "bg-[#550015] text-white" 
            : "bg-[#eae9db] text-[#1c1c14] hover:bg-[#e5e3d5]"
        ]}
      >
        {category.name}
      </span>
    ))}
  </div>
</section>
