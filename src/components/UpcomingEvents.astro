---
// Este componente mostrara eventos proximos
// Los datos vendran de Contentful en el futuro
const events = [
  {
    id: 1,
    type: "conference",
    date: "14-16 Marzo, 2024",
    title: "Foro Global de Constitucionalismo",
    description: "Unete a juristas internacionales para tres dias de deliberacion sobre el futuro de las instituciones democraticas.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuAz9q_6pbgcJsok1KxRmbTfddIGMz8jQiTQ6wh2qYmMPjKM_K_pQ9DcNGKLNIGL7mc4TfL-CbhFeWtFzaEPEHnuVLKth9EmTPvWBOpk_IvbR0cWNWKf1TL2SMHohvvwmhKzF5sMj-KRsa9lvKNZ1odrHo6BAUXhF5MSoNvLzbVTalJMQIEVu5KT3XEut-OqJH0OAlmIJ3TxjblGye7Cuc-rdkq6ppHDZUgEsYvcXzvCIy-n_4A67462NFEmZYMbSKoBteKaWbTUeTX4"
  },
  {
    id: 2,
    type: "lecture",
    date: "02 Abril, 2024",
    title: "La Etica de la IA en Procedimientos Legales",
    description: "La Profesora Elena Moretti explora los limites del juicio algoritmico en la litigacion moderna."
  },
  {
    id: 3,
    type: "webinar",
    title: "Actualizaciones en Derecho Maritimo",
    description: "Sesion informativa virtual quincenal para investigadores de posgrado."
  },
  {
    id: 4,
    type: "workshop",
    title: "Redaccion Legal",
    description: "Sesion intensiva para candidatos a graduarse en derecho."
  }
];
---

<section class="py-2 md:py-4 bg-[#fcfaec]">
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <div class="text-center mb-10 md:mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-headline font-bold text-[#2e0007] mb-4">Momentos destacados</h2>
      <div class="h-1 w-24 bg-[#2e0007] mx-auto"></div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6 auto-rows-auto md:h-[600px]">
      <!-- Event 1 (Large) -->
      <div class="md:col-span-7 relative rounded-2xl overflow-hidden group min-h-[300px] md:min-h-0">
        <img 
          alt="Escenario de simposio profesional con audiencia"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          src={events[0].image}
          width="800"
          height="450"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#2e0007]/90 via-[#2e0007]/40 to-transparent"></div>
        <div class="absolute bottom-0 p-6 md:p-10 text-white">
          <p class="font-label text-xs font-bold uppercase tracking-widest text-[#ffdadb] mb-2">
            {events[0].date}
          </p>
          <h3 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold mb-4">{events[0].title}</h3>
          <p class="font-body text-white/80 max-w-md mb-6 text-sm md:text-base">{events[0].description}</p>
          <button class="bg-white text-[#2e0007] px-6 py-2 rounded font-label font-bold text-sm">
            Registrar Asistencia
          </button>
        </div>
      </div>
      
      <!-- Event 2 (Tall) -->
      <div class="md:col-span-5 md:row-span-2 bg-[#eae9db] rounded-2xl p-6 md:p-8 flex flex-col justify-between border border-[#dcc0c1]/20">
        <div>
          <span class="bg-[#550015] text-white px-3 py-1 rounded-full text-[10px] font-label font-bold uppercase tracking-tighter mb-6 md:mb-8 inline-block">
            Conferencia Especial
          </span>
          <h3 class="text-2xl md:text-3xl font-headline font-bold text-[#2e0007] mb-4 leading-tight">
            {events[1].title}
          </h3>
          <p class="font-body text-[#564243] mb-6 leading-relaxed text-sm md:text-base">
            {events[1].description}
          </p>
        </div>
        <div class="bg-white/50 backdrop-blur p-4 rounded-xl">
          <div class="flex items-center justify-between">
            <span class="font-label font-bold text-[#2e0007] text-sm">{events[1].date}</span>
            <span class="material-symbols-outlined text-[#2e0007]">calendar_today</span>
          </div>
        </div>
      </div>
      
      <!-- Event 3 (Small) -->
      <div class="md:col-span-4 bg-[#fdcbce] rounded-2xl p-6 md:p-8 hover:bg-[#ffdadb] transition-colors">
        <p class="font-label text-xs font-bold uppercase text-[#7a5356] mb-4">Serie de Webinars</p>
        <h4 class="text-xl md:text-2xl font-headline font-bold text-[#2f1316] mb-2">{events[2].title}</h4>
        <p class="text-[#603d40] text-sm font-body">{events[2].description}</p>
      </div>
      
      <!-- Event 4 (Small) -->
      <div class="md:col-span-3 bg-white rounded-2xl p-6 md:p-8 border border-[#dcc0c1]/10">
        <p class="font-label text-xs font-bold uppercase text-[#2e0007] mb-4">Taller</p>
        <h4 class="text-xl md:text-2xl font-headline font-bold text-[#2e0007] mb-2">{events[3].title}</h4>
        <p class="text-[#564243] text-sm font-body">{events[3].description}</p>
      </div>
    </div>
  </div>
</section>
