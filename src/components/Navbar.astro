---
import { Image } from 'astro:assets';
import logoDetraVf from '../assets/images/logoDetravf.png';

interface Props {
  currentPage?: "home" | "publications" | "about";
}

const { currentPage = "home" } = Astro.props;
---

<nav
  id="main-nav"
  class="bg-[#fcfaec]/80 backdrop-blur-md sticky top-0 z-50 transition-all duration-500"
>
  <!-- Línea decorativa superior — acento editorial -->
  <div
    class="h-[2px] w-full bg-gradient-to-r from-transparent via-[#5E0B15]/60 to-transparent"
  >
  </div>

  <div
    class="flex justify-between items-center w-full px-6 md:px-10 py-3 max-w-7xl mx-auto"
  >
    <!-- Brand Logo -->
    <a
      href="/"
      class="flex items-center group"
      aria-label="Ir al inicio de Detra"
    >
      <Image
        src={logoDetraVf}
        alt="Detra logo"
        width={400}
        class="h-12 w-auto object-contain transition-transform duration-300 group-hover:scale-[1.03]"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <!-- Navigation Links — desktop -->
    <div class="hidden md:flex items-center gap-10">
      <a
        class:list={[
          "nav-link relative font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200",
          currentPage === "home"
            ? "text-[#5E0B15] font-bold nav-link--active"
            : "text-[#1c1c14]/60 hover:text-[#5E0B15]",
        ]}
        href="/"
        data-astro-prefetch
      >
        Inicio
      </a>
      <a
        class:list={[
          "nav-link relative font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200",
          currentPage === "publications"
            ? "text-[#550015] font-bold nav-link--active"
            : "text-[#1c1c14]/60 hover:text-[#550015]",
        ]}
        href="/publicaciones"
        data-astro-prefetch
      >
        Publicaciones
      </a>
      <a
        class:list={[
          "nav-link relative font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200",
          currentPage === "about"
            ? "text-[#5E0B15] font-bold nav-link--active"
            : "text-[#1c1c14]/60 hover:text-[#5E0B15]",
        ]}
        href="/sobrenosotros"
        data-astro-prefetch
      >
        Sobre Nosotros
      </a>
    </div>

    <!-- Acciones trailing — desktop -->
    <div class="hidden md:flex items-center gap-5">
      <button
        class="material-symbols-outlined text-[#2e0007]/70 hover:text-[#5E0B15] transition-all duration-200 hover:scale-110"
        aria-label="Acceder al directorio"
      >
        account_balance
      </button>
      <a href="/?motivo=contacto#contacto">
        <button
          class="group relative overflow-hidden bg-[#5E0B15] cursor-pointer text-white px-5 py-2 rounded-[3px] font-label text-xs tracking-[0.12em] uppercase font-semibold transition-all duration-300 hover:shadow-[0_4px_20px_rgba(94,11,21,0.35)]"
        >
          <!-- Shimmer on hover -->
          <span
            class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-500 bg-gradient-to-r from-transparent via-white/15 to-transparent"
          ></span>
          <span class="relative">CONTACTO</span>
        </button>
      </a>
    </div>

    <!-- Botón hamburguesa — mobile -->
    <button
      id="mobile-menu-btn"
      class="md:hidden cursor-pointer flex flex-col justify-center items-center w-9 h-9 rounded-sm border border-[#dcc0c1]/50 hover:border-[#5E0B15]/40 hover:bg-[#5E0B15]/5 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#550015]"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span
        class="hamburger-line block w-[18px] h-[1.5px] bg-[#5E0B15] rounded-full transition-all duration-300 origin-center"
      ></span>
      <span
        class="hamburger-line block w-[18px] h-[1.5px] bg-[#5E0B15] rounded-full transition-all duration-300 mt-[5px] origin-center"
      ></span>
      <span
        class="hamburger-line block w-[18px] h-[1.5px] bg-[#5E0B15] rounded-full transition-all duration-300 mt-[5px] origin-center"
      ></span>
    </button>
  </div>

  <!-- Menú mobile - GPU accelerated con transform/opacity -->
  <div
    id="mobile-menu"
    class="md:hidden absolute top-full left-0 w-full opacity-0 pointer-events-none -translate-y-2 transition-all duration-300 ease-out shadow-lg"
    inert
  >
    <div
      class="bg-[#fcfaec] border-t border-[#dcc0c1]/40 px-8 py-6 flex flex-col gap-6"
    >
      <!-- Links móvil -->
      <div class="flex flex-col gap-5">
        <a
          class:list={[
            "font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200 w-fit",
            currentPage === "home"
              ? "text-[#5E0B15] font-bold mobile-link--active"
              : "text-[#1c1c14]/60 hover:text-[#5E0B15]",
          ]}
          href="/"
          data-astro-prefetch
        >
          Inicio
        </a>
        <a
          class:list={[
            "font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200 w-fit",
            currentPage === "publications"
              ? "text-[#5E0B15] font-bold mobile-link--active"
              : "text-[#1c1c14]/60 hover:text-[#5E0B15]",
          ]}
          href="/publicaciones"
          data-astro-prefetch
        >
          Publicaciones
        </a>
        <a
          class:list={[
            "font-label text-xs tracking-[0.14em] uppercase transition-colors duration-200 w-fit",
            currentPage === "about"
              ? "text-[#5E0B15] font-bold mobile-link--active"
              : "text-[#1c1c14]/60 hover:text-[#5E0B15]",
          ]}
          href="/sobrenosotros"
          data-astro-prefetch
        >
          Sobre Nosotros
        </a>
      </div>

      <!-- Divisor -->
      <div class="h-px bg-gradient-to-r from-[#dcc0c1]/60 to-transparent"></div>

      <!-- Acciones móvil -->
      <div class="flex items-center gap-5">
        <button
          class="material-symbols-outlined text-[#2e0007]/70 hover:text-[#5E0B15] transition-colors duration-200"
          aria-label="Acceder al directorio"
        >
          account_balance
        </button>
        <a href="/?motivo=contacto#contacto" class="flex-1">
          <button
            class="w-full bg-[#5E0B15] text-white px-5 py-2.5 rounded-[3px] font-label text-xs tracking-[0.12em] uppercase font-semibold hover:opacity-90 transition-all duration-200 cursor-pointer"
          >
            CONTACTO
          </button>
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Indicador de página activa — línea inferior animada */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: #5e0b15;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }
  .nav-link--active::after {
    transform: scaleX(1);
  }

  /* Indicador activo en móvil */
  .mobile-link--active {
    position: relative;
    padding-left: 12px;
  }
  .mobile-link--active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 100%;
    background-color: #5e0b15;
    border-radius: 2px;
  }

  /* Hamburger open state */
  #mobile-menu-btn.is-open .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  #mobile-menu-btn.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #mobile-menu-btn.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Scrolled state */
  #main-nav.scrolled {
    background-color: rgba(252, 250, 236, 0.96);
    box-shadow:
      0 1px 0 rgba(220, 192, 193, 0.5),
      0 4px 16px rgba(46, 0, 7, 0.06);
  }

  /* ══════════════════════════════════════════════════════════════════════════
     Mobile Menu - GPU Accelerated Animation
     Usa transform y opacity (propiedades que no causan reflow)
     will-change aplicado solo durante la transición para evitar overhead
     ══════════════════════════════════════════════════════════════════════════ */
  #mobile-menu {
    /* Promueve el elemento a su propia capa GPU */
    will-change: transform, opacity;
    backface-visibility: hidden;
    /* Estado cerrado por defecto (definido también en las clases Tailwind) */
    transform: translateY(-8px);
  }

  #mobile-menu.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>

<script>
  // ── AbortController para limpieza de listeners de este componente ──
  let navAbortController: AbortController | null = null;

  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn") as HTMLButtonElement | null;
    const menu = document.getElementById("mobile-menu") as HTMLDivElement | null;
    const nav = document.getElementById("main-nav") as HTMLElement | null;
    
    // Guard: salir si no existen los elementos necesarios
    if (!btn || !menu || !nav) return;

    // Limpiar listeners antiguos si existen
    if (navAbortController) {
      navAbortController.abort();
    }

    // Crear nuevo AbortController
    navAbortController = new AbortController();
    const { signal } = navAbortController;

    // ══════════════════════════════════════════════════════════════════════════
    // Scroll handler optimizado con rAF y estado cacheado
    // ══════════════════════════════════════════════════════════════════════════
    let isScrolled = nav.classList.contains("scrolled");
    let rafPending = false;

    const handleScroll = () => {
      if (rafPending) return;
      rafPending = true;

      requestAnimationFrame(() => {
        rafPending = false;
        const shouldBeScrolled = window.scrollY > 12;
        
        if (shouldBeScrolled !== isScrolled) {
          isScrolled = shouldBeScrolled;
          nav.classList.toggle("scrolled", isScrolled);
        }
      });
    };
    
    window.addEventListener("scroll", handleScroll, { passive: true, signal });
    
    // Verificación inicial
    requestAnimationFrame(() => {
      const shouldBeScrolled = window.scrollY > 12;
      if (shouldBeScrolled !== isScrolled) {
        isScrolled = shouldBeScrolled;
        nav.classList.toggle("scrolled", isScrolled);
      }
    });

    // ══════════════════════════════════════════════════════════════════════════
    // Mobile Menu Toggle - GPU accelerated (solo clases, sin cálculos)
    // ══════════════════════════════════════════════════════════════════════════
    
    /** Abre el menú móvil */
    function openMenu() {
      btn!.classList.add("is-open");
      btn!.setAttribute("aria-expanded", "true");
      menu!.classList.add("is-active");
      menu!.inert = false;
    }

    /** Cierra el menú móvil */
    function closeMenu() {
      btn!.classList.remove("is-open");
      btn!.setAttribute("aria-expanded", "false");
      menu!.classList.remove("is-active");
      menu!.inert = true;
    }

    /** Toggle del menú */
    function toggleMenu() {
      const isOpen = btn!.classList.contains("is-open");
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    // Click en el botón hamburguesa
    btn!.addEventListener("click", toggleMenu, { signal });

    // Cerrar menú al hacer click en links (navegación)
    menu!.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu, { signal });
    });

    // Cerrar menú al hacer resize a desktop
    let resizeRafPending = false;
    window.addEventListener("resize", () => {
      if (resizeRafPending) return;
      resizeRafPending = true;

      requestAnimationFrame(() => {
        resizeRafPending = false;
        const isWideScreen = window.innerWidth >= 768;
        const isMenuOpen = btn!.classList.contains("is-open");
        
        if (isWideScreen && isMenuOpen) {
          closeMenu();
        }
      });
    }, { signal });

    // Cerrar menú con Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && btn!.classList.contains("is-open")) {
        closeMenu();
        btn!.focus(); // Devolver foco al botón
      }
    }, { signal });
  }

  // ── Inicialización con astro:page-load ──
  document.addEventListener('astro:page-load', initMobileMenu);

  // ── Limpieza antes de swap ──
  document.addEventListener('astro:before-swap', () => {
    if (navAbortController) {
      navAbortController.abort();
      navAbortController = null;
    }
  });
</script>
